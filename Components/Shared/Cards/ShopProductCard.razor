@using SubashaVentures.Domain.Product
@using SubashaVentures.Services.Wishlist
@using SubashaVentures.Services.Cart
@using SubashaVentures.Services.Authorization
@using SubashaVentures.Services.Products
@using SubashaVentures.Services.VisualElements
@using SubashaVentures.Domain.Enums
@using SubashaVentures.Models.Supabase
@inject NavigationManager NavigationManager
@inject IPermissionService PermissionService
@inject ICartService CartService
@inject IWishlistService WishlistService
@inject IProductInteractionService InteractionService
@inject IVisualElementsService VisualElementsService

<div class="shop-product-card @(Product.IsFeatured ? "featured" : "") @(!Product.IsOwnedByStore ? "partner-product" : "")"
     @onclick="HandleCardClick">

    @* Image Section *@
    <div class="product-image-container">
        @if (HasValidImage)
        {
            <img src="@GetImageUrl()"
                 alt="@Product.Name"
                 class="product-image"
                 loading="lazy"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
            <div class="product-image-placeholder" style="display: none;">
                <span class="placeholder-emoji">📦</span>
            </div>
        }
        else
        {
            <div class="product-image-placeholder">
                <span class="placeholder-emoji">📦</span>
            </div>
        }

        @* Badges *@
        <div class="product-badges">
            @if (Product.IsFeatured)
            {
                <span class="badge badge-featured">
                    @if (!string.IsNullOrEmpty(flameSvg))
                    {
                        <span class="badge-icon">@((MarkupString)flameSvg)</span>
                    }
                    <span>Featured</span>
                </span>
            }
            @if (Product.IsOnSale && Product.Discount > 0)
            {
                <span class="badge badge-sale">-@Product.Discount%</span>
            }
            @if (IsInCart)
            {
                <span class="badge badge-in-cart">
                    @if (!string.IsNullOrEmpty(checkMarkSvg))
                    {
                        <span class="badge-icon">@((MarkupString)checkMarkSvg)</span>
                    }
                    <span>In Cart</span>
                </span>
            }
        </div>

        @* Partner label — bottom-left of image *@
        @if (!Product.IsOwnedByStore && !string.IsNullOrEmpty(Product.PartnerName))
        {
            <div class="partner-label" @onclick="HandlePartnerClick" @onclick:stopPropagation="true"
                 title="Sold by @Product.PartnerName — visit their store">
                <span class="partner-label-icon">🤝</span>
                <span class="partner-label-text">@Product.PartnerName</span>
            </div>
        }
    </div>

    @* Product Details *@
    <div class="product-details">

        @* Category & Brand *@
        <div class="product-meta">
            <span class="category">@Product.Category.ToUpper()</span>
            @if (!string.IsNullOrEmpty(Product.Brand))
            {
                <span class="separator">•</span>
                <span class="brand">@Product.Brand</span>
            }
        </div>

        @* Name & Price *@
        <div class="product-header">
            <h3 class="product-name" title="@Product.Name">
                @Product.Name
            </h3>
            <div class="product-pricing">
                <span class="current-price">@Product.DisplayPrice</span>
                @if (Product.IsOnSale && Product.OriginalPrice.HasValue)
                {
                    <span class="original-price">@Product.DisplayOriginalPrice</span>
                }
            </div>
        </div>

        @* Rating *@
        @if (Product.Rating > 0)
        {
            <div class="product-rating">
                <div class="stars">
                    @if (!string.IsNullOrEmpty(starSvg))
                    {
                        @for (int i = 0; i < 5; i++)
                        {
                            int starIndex = i;
                            <span class="star @(starIndex < Math.Floor(Product.Rating) ? "filled" : "")">
                                @((MarkupString)starSvg)
                            </span>
                        }
                    }
                </div>
                <span class="rating-text">
                    @Product.DisplayRating (@Product.ReviewCount)
                </span>
            </div>
        }

        @* Action Buttons *@
        <div class="product-actions">
            <button class="btn-add-cart @(Product.IsInStock ? "" : "disabled") @(IsAddingToCart ? "loading" : "")"
                    @onclick="HandleAddToCart"
                    @onclick:stopPropagation="true"
                    disabled="@(!Product.IsInStock || IsAddingToCart)">
                @if (IsAddingToCart)
                {
                    <span class="spinner-small"></span>
                    <span>Adding...</span>
                }
                else if (IsInCart)
                {
                    @if (!string.IsNullOrEmpty(checkMarkSvg))
                    {
                        <span class="btn-icon">@((MarkupString)checkMarkSvg)</span>
                    }
                    <span>IN CART</span>
                }
                else if (Product.IsInStock)
                {
                    @if (!string.IsNullOrEmpty(cartSvg))
                    {
                        <span class="btn-icon">@((MarkupString)cartSvg)</span>
                    }
                    <span>ADD TO CART</span>
                }
                else
                {
                    <span>OUT OF STOCK</span>
                }
            </button>

            <button class="btn-favorite @(IsFavorite ? "active" : "") @(IsTogglingWishlist ? "loading" : "")"
                    @onclick="HandleToggleFavorite"
                    @onclick:stopPropagation="true"
                    disabled="@IsTogglingWishlist"
                    title="@(IsFavorite ? "Remove from favorites" : "Add to favorites")">
                @if (IsTogglingWishlist)
                {
                    <span class="spinner-small"></span>
                }
                else if (!string.IsNullOrEmpty(heartSvg))
                {
                    <span class="heart-icon @(IsFavorite ? "filled" : "")">
                        @((MarkupString)heartSvg)
                    </span>
                }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public ProductViewModel Product { get; set; } = null!;
    [Parameter] public EventCallback<int> OnAddToCart { get; set; }
    [Parameter] public EventCallback<int> OnToggleFavorite { get; set; }

    private bool IsFavorite { get; set; }
    private bool IsInCart { get; set; }
    private bool IsAddingToCart { get; set; }
    private bool IsTogglingWishlist { get; set; }
    private string? currentUserId;

    private string starSvg      = string.Empty;
    private string heartSvg     = string.Empty;
    private string cartSvg      = string.Empty;
    private string checkMarkSvg = string.Empty;
    private string flameSvg     = string.Empty;

    private bool HasValidImage =>
        Product?.Images != null &&
        Product.Images.Any() &&
        !string.IsNullOrWhiteSpace(Product.Images.First());

    protected override async Task OnInitializedAsync()
    {
        await LoadSvgsAsync();

        if (await PermissionService.IsAuthenticatedAsync())
        {
            currentUserId = await PermissionService.GetCurrentUserIdAsync();
            if (!string.IsNullOrEmpty(currentUserId))
            {
                IsFavorite = await WishlistService.IsInWishlistAsync(currentUserId, Product.Id.ToString());
                IsInCart   = await CartService.IsInCartAsync(currentUserId, Product.Id.ToString());
            }
        }
    }

    private async Task LoadSvgsAsync()
    {
        try
        {
            var results = await Task.WhenAll(
                VisualElementsService.GetCustomSvgAsync(SvgType.Star,      width: 16, height: 16, fillColor: "currentColor"),
                VisualElementsService.GetCustomSvgAsync(SvgType.Heart,     width: 20, height: 20, fillColor: "currentColor"),
                VisualElementsService.GetCustomSvgAsync(SvgType.Cart,      width: 18, height: 18, fillColor: "currentColor"),
                VisualElementsService.GetCustomSvgAsync(SvgType.CheckMark, width: 16, height: 16, fillColor: "currentColor"),
                VisualElementsService.GetCustomSvgAsync(SvgType.Flame,     width: 14, height: 14, fillColor: "currentColor")
            );

            starSvg      = results[0];
            heartSvg     = results[1];
            cartSvg      = results[2];
            checkMarkSvg = results[3];
            flameSvg     = results[4];
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading SVGs: {ex.Message}");
        }
    }

    private string GetImageUrl() =>
        Product?.Images?.FirstOrDefault(i => !string.IsNullOrWhiteSpace(i)) ?? string.Empty;

    private async Task HandleCardClick()
    {
        if (!string.IsNullOrEmpty(currentUserId))
            await InteractionService.TrackClickAsync(Product.Id, currentUserId);

        NavigationManager.NavigateTo($"product/{Product.Slug}");
    }

    // Clicking the partner label goes to the partner store page
    private void HandlePartnerClick()
    {
        if (Product.PartnerId.HasValue)
            NavigationManager.NavigateTo($"store/partner/{Product.PartnerId.Value}");
    }

    private async Task HandleAddToCart(MouseEventArgs e)
    {
        if (!Product.IsInStock || IsAddingToCart) return;

        IsAddingToCart = true;
        StateHasChanged();

        try
        {
            if (!await PermissionService.EnsureAuthenticatedAsync($"product/{Product.Slug}"))
                return;

            if (string.IsNullOrEmpty(currentUserId))
                currentUserId = await PermissionService.GetCurrentUserIdAsync();

            if (string.IsNullOrEmpty(currentUserId))
            {
                PermissionService.ShowAuthRequiredMessage("add items to cart");
                return;
            }

            string? selectedSize  = null;
            string? selectedColor = null;

            if (Product.Variants != null && Product.Variants.Any())
            {
                var first = Product.Variants.First();
                selectedSize  = first.Value.Size;
                selectedColor = first.Value.Color;
            }

            var success = await CartService.AddToCartAsync(
                currentUserId,
                Product.Id.ToString(),
                quantity: 1,
                size: selectedSize,
                color: selectedColor);

            if (success)
            {
                IsInCart = true;
                if (OnAddToCart.HasDelegate)
                    await OnAddToCart.InvokeAsync(Product.Id);
            }
        }
        finally
        {
            IsAddingToCart = false;
            StateHasChanged();
        }
    }

    private async Task HandleToggleFavorite(MouseEventArgs e)
    {
        if (IsTogglingWishlist) return;

        IsTogglingWishlist = true;
        StateHasChanged();

        try
        {
            if (!await PermissionService.EnsureAuthenticatedAsync($"product/{Product.Slug}"))
                return;

            if (string.IsNullOrEmpty(currentUserId))
                currentUserId = await PermissionService.GetCurrentUserIdAsync();

            if (string.IsNullOrEmpty(currentUserId))
            {
                PermissionService.ShowAuthRequiredMessage("add items to wishlist");
                return;
            }

            var success = await WishlistService.ToggleWishlistAsync(currentUserId, Product.Id.ToString());

            if (success)
            {
                IsFavorite = !IsFavorite;
                if (OnToggleFavorite.HasDelegate)
                    await OnToggleFavorite.InvokeAsync(Product.Id);
            }
        }
        finally
        {
            IsTogglingWishlist = false;
            StateHasChanged();
        }
    }
}
