@* Components/Shared/Popups/ImageSelectorPopup.razor *@
@using Microsoft.AspNetCore.Components.Web
@using SubashaVentures.Components.Shared.Buttons
@using SubashaVentures.Components.Admin.Images

<div class="image-selector-overlay @(IsOpen ? "open" : "")" @onclick="HandleOverlayClick">
    <div class="image-selector-popup @(IsOpen ? "open" : "")" @onclick:stopPropagation="true">

        <!-- ── Header ── -->
        <div class="isp-header">
            <div class="isp-header-left">
                <h2 class="isp-title">@(AllowMultiple ? "Select Images" : "Select Image")</h2>
                <p class="isp-subtitle">
                    @if (SelectedImages.Count > 0)
                    {
                        <span class="isp-count">@SelectedImages.Count selected</span>
                    }
                    else if (isLoading)
                    {
                        <span>Loading images…</span>
                    }
                    else
                    {
                        <span>Choose from your media library</span>
                    }
                </p>
            </div>
            <button class="isp-close" @onclick="HandleClose" title="Close">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                    <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>
        </div>

        <!-- ── Toolbar ── -->
        <div class="isp-toolbar">
            <!-- Search -->
            <div class="isp-search-box">
                <svg class="isp-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
                    <path d="M21 21L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <input class="isp-search-input"
                       type="text"
                       placeholder="Search images…"
                       value="@searchQuery"
                       @oninput="HandleSearchInput"
                       @onkeydown="HandleSearchKeyDown" />
                @if (!string.IsNullOrEmpty(searchQuery))
                {
                    <button class="isp-search-clear" @onclick="ClearSearch" title="Clear">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                            <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </button>
                }
            </div>

            <!-- Filters row -->
            <div class="isp-filters-row">
                <!-- Category -->
                <div class="isp-filter-group">
                    <label class="isp-filter-label">Category</label>
                    <div class="isp-select-wrap">
                        <select class="isp-select" value="@selectedFolder" @onchange="HandleFolderFilter">
                            <option value="">All</option>
                            @foreach (var cat in categories.Where(c => c.IsActive).OrderBy(c => c.DisplayOrder))
                            {
                                <option value="@cat.Slug">@cat.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Sort -->
                <div class="isp-filter-group">
                    <label class="isp-filter-label">Sort</label>
                    <div class="isp-select-wrap">
                        <select class="isp-select" value="@sortBy" @onchange="HandleSortChange">
                            <option value="newest">Newest first</option>
                            <option value="oldest">Oldest first</option>
                            <option value="name-az">Name A–Z</option>
                            <option value="name-za">Name Z–A</option>
                            <option value="size-largest">Size (largest)</option>
                            <option value="size-smallest">Size (smallest)</option>
                            <option value="type-az">Type A–Z</option>
                        </select>
                    </div>
                </div>

                <!-- Per page -->
                <div class="isp-filter-group">
                    <label class="isp-filter-label">Per page</label>
                    <div class="isp-select-wrap">
                        <select class="isp-select" value="@pageSize" @onchange="HandlePageSizeChange">
                            <option value="12">12</option>
                            <option value="24">24</option>
                            <option value="48">48</option>
                            <option value="96">96</option>
                        </select>
                    </div>
                </div>

                @if (HasActiveFilters)
                {
                    <button class="isp-reset-btn" @onclick="ResetAllFilters">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                            <path d="M3 12C3 7.03 7.03 3 12 3C16.97 3 21 7.03 21 12C21 16.97 16.97 21 12 21C9.17 21 6.66 19.64 5 17.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <path d="M3 8V12H7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        Reset
                    </button>
                }

                <!-- View size -->
                <div class="isp-view-toggles">
                    <button class="isp-view-btn @(viewSize == "small"  ? "active" : "")" @onclick='() => SetViewSize("small")'  title="Small">
                        <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor">
                            <rect x="0" y="0" width="6" height="6" rx="1"/>
                            <rect x="10" y="0" width="6" height="6" rx="1"/>
                            <rect x="0" y="10" width="6" height="6" rx="1"/>
                            <rect x="10" y="10" width="6" height="6" rx="1"/>
                        </svg>
                    </button>
                    <button class="isp-view-btn @(viewSize == "medium" ? "active" : "")" @onclick='() => SetViewSize("medium")' title="Medium">
                        <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor">
                            <rect x="0" y="0" width="7" height="7" rx="1"/>
                            <rect x="9" y="0" width="7" height="7" rx="1"/>
                            <rect x="0" y="9" width="7" height="7" rx="1"/>
                            <rect x="9" y="9" width="7" height="7" rx="1"/>
                        </svg>
                    </button>
                    <button class="isp-view-btn @(viewSize == "large"  ? "active" : "")" @onclick='() => SetViewSize("large")'  title="Large">
                        <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor">
                            <rect x="0" y="0" width="16" height="7" rx="1"/>
                            <rect x="0" y="9" width="16" height="7" rx="1"/>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Active filter pills -->
            @if (HasActiveFilters)
            {
                <div class="isp-pills">
                    @if (!string.IsNullOrEmpty(searchQuery))
                    {
                        <span class="isp-pill">
                            Search: "@searchQuery"
                            <button @onclick="ClearSearch">×</button>
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(selectedFolder))
                    {
                        <span class="isp-pill">
                            Category: @GetCategoryName(selectedFolder)
                            <button @onclick='() => { selectedFolder = ""; ApplyFilters(); }'>×</button>
                        </span>
                    }
                </div>
            }
        </div>

        <!-- ── Results bar ── -->
        @if (!isLoading || allImages.Any())
        {
            <div class="isp-results-bar">
                <span class="isp-results-count">
                    @if (isLoadingMore)
                    {
                        <span class="isp-loading-more-badge">
                            <span class="isp-mini-spinner"></span>
                            Loading @loadedFolderCount / @totalFolderCount categories…
                        </span>
                    }
                    else if (filteredImages.Count > 0)
                    {
                        @(HasActiveFilters
                            ? $"{filteredImages.Count} of {allImages.Count} images"
                            : $"{allImages.Count} image{(allImages.Count != 1 ? "s" : "")}")
                    }
                </span>
                @if (!AllowMultiple && SelectedImages.Count > 0)
                {
                    <button class="isp-clear-selection" @onclick="ClearSelection">Clear selection</button>
                }
            </div>
        }

        <!-- ── Image Grid ── -->
        <div class="isp-content">
            @if (isLoading && !allImages.Any())
            {
                <div class="isp-state-block">
                    <div class="isp-spinner"></div>
                    <p>Loading images…</p>
                    @if (totalFolderCount > 0)
                    {
                        <div class="isp-load-progress">
                            <div class="isp-load-bar" style="width: @loadingProgress%"></div>
                        </div>
                        <span class="isp-load-text">@loadedFolderCount of @totalFolderCount categories</span>
                    }
                </div>
            }
            else if (!pagedImages.Any() && !isLoading && !isLoadingMore)
            {
                <div class="isp-state-block">
                    <div class="isp-empty-icon">
                        @if (HasActiveFilters)
                        {
                            <svg width="56" height="56" viewBox="0 0 24 24" fill="none">
                                <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5"/>
                                <path d="M21 21L16.65 16.65" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                        }
                        else
                        {
                            <svg width="56" height="56" viewBox="0 0 24 24" fill="none">
                                <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                                <path d="M3 16L8 11L11 14L15 10L21 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                <circle cx="8.5" cy="8.5" r="1.5" stroke="currentColor" stroke-width="1.5"/>
                            </svg>
                        }
                    </div>
                    <h3>@(HasActiveFilters ? "No images match your filters" : "No images available")</h3>
                    <p>@(HasActiveFilters ? "Try adjusting your search or category." : "Upload images first.")</p>
                    @if (HasActiveFilters)
                    {
                        <button class="isp-reset-btn prominent" @onclick="ResetAllFilters">Reset filters</button>
                    }
                </div>
            }
            else
            {
                <div class="isp-grid @viewSize">
                    @foreach (var image in pagedImages)
                    {
                        var isSelected = SelectedImages.Contains(image.PublicUrl);
                        <AdminImageCard Image="@image"
                                        IsSelected="@isSelected"
                                        ShowActions="false"
                                        OnClick="@(() => HandleImageSelect(image))"
                                        OnSelectionChanged="@(_ => HandleImageSelect(image))" />
                    }

                    @if (isLoadingMore)
                    {
                        @for (int i = 0; i < 4; i++)
                        {
                            <div class="isp-skeleton-card">
                                <div class="isp-skeleton-img"></div>
                                <div class="isp-skeleton-info">
                                    <div class="isp-skeleton-line"></div>
                                    <div class="isp-skeleton-line short"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>

        <!-- ── Pagination ── -->
        @if (totalPages > 1)
        {
            <div class="isp-pagination">
                <button class="isp-page-btn prev-next"
                        @onclick="PreviousPage"
                        disabled="@(currentPage <= 1)">
                    ← Prev
                </button>

                @{
                    var startPg = Math.Max(1, currentPage - 2);
                    var endPg   = Math.Min(totalPages, currentPage + 2);

                    if (startPg > 1)
                    {
                        <button class="isp-page-btn" @onclick="@(() => GoToPage(1))">1</button>
                        if (startPg > 2) { <span class="isp-page-ellipsis">…</span> }
                    }

                    for (int pg = startPg; pg <= endPg; pg++)
                    {
                        var cap = pg;
                        <button class="isp-page-btn @(cap == currentPage ? "active" : "")"
                                @onclick="@(() => GoToPage(cap))">
                            @cap
                        </button>
                    }

                    if (endPg < totalPages)
                    {
                        if (endPg < totalPages - 1) { <span class="isp-page-ellipsis">…</span> }
                        <button class="isp-page-btn" @onclick="@(() => GoToPage(totalPages))">@totalPages</button>
                    }
                }

                <button class="isp-page-btn prev-next"
                        @onclick="NextPage"
                        disabled="@(currentPage >= totalPages)">
                    Next →
                </button>

                <span class="isp-page-info">
                    @((currentPage - 1) * pageSize + 1)–@Math.Min(currentPage * pageSize, filteredImages.Count)
                    of @filteredImages.Count
                </span>
            </div>
        }

        <!-- ── Footer ── -->
        <div class="isp-footer">
            <div class="isp-footer-info">
                @if (SelectedImages.Count > 0)
                {
                    <span class="isp-selected-count">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        @SelectedImages.Count image@(SelectedImages.Count != 1 ? "s" : "") selected
                    </span>
                }
            </div>
            <div class="isp-footer-actions">
                <SecondaryButton Variant="SecondaryButton.ButtonVariant.Outline"
                                 Size="SecondaryButton.ButtonSize.Medium"
                                 OnClick="HandleClose">
                    Cancel
                </SecondaryButton>
                <PrimaryButton Size="PrimaryButton.ButtonSize.Medium"
                               OnClick="HandleConfirm"
                               IsDisabled="@(SelectedImages.Count == 0)">
                    @(AllowMultiple
                        ? (SelectedImages.Count > 0
                            ? $"Select {SelectedImages.Count} image{(SelectedImages.Count != 1 ? "s" : "")}"
                            : "Select Images")
                        : "Select Image")
                </PrimaryButton>
            </div>
        </div>

    </div>
</div>
