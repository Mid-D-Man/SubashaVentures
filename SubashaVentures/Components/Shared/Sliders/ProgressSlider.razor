@* ProgressSlider.razor - Test component for SCSS functionality *@
<div class="progress-slider-container">
    <h3 class="slider-title">Interactive Progress Slider</h3>
    <p class="slider-description">Testing SCSS compilation with a color-changing progress bar</p>
    
    <div class="slider-wrapper">
        <div class="progress-track">
            <div class="progress-fill" style="width: @(progress)%"></div>
            <div class="progress-thumb" style="left: @(progress)%"></div>
        </div>
        
        <div class="slider-controls">
            <input type="range" 
                   min="0" 
                   max="100" 
                   step="1"
                   @bind="progress" 
                   @oninput="HandleProgressChange"
                   class="range-input" />
        </div>
        
        <div class="progress-info">
            <span class="progress-value">@progress%</span>
            <span class="progress-status">@GetStatusText()</span>
        </div>
    </div>
    
    <div class="color-indicators">
        <div class="color-dot green @(progress < 33 ? "active" : "")"></div>
        <div class="color-dot yellow @(progress >= 33 && progress < 66 ? "active" : "")"></div>
        <div class="color-dot red @(progress >= 66 ? "active" : "")"></div>
    </div>
</div>

@code {
    private int progress = 25;

    private void HandleProgressChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
        {
            progress = value;
            StateHasChanged();
        }
    }

    private string GetStatusText()
    {
        return progress switch
        {
            < 33 => "Getting Started",
            < 66 => "Making Progress",
            < 90 => "Almost There",
            _ => "Complete!"
        };
    }
}