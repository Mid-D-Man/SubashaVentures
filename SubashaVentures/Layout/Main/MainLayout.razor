@inherits LayoutComponentBase

<div class="main-layout">
    <!-- Top Section - Navigation (6% height) -->
    <header class="layout-top">
        <TopNavigation />
    </header>

    <!-- Middle Section - Page Content (64% height with scroll) -->
    <main class="layout-middle">
        <div class="page-content">
            @Body
        </div>
    </main>

    <!-- Bottom Section - Footer Info (30% height) -->
    <footer class="layout-bottom">
        <FooterSection />
    </footer>
</div>
