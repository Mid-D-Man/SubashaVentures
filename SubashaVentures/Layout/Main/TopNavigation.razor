@using SubashaVentures.Components.Shared.Buttons

<nav class="top-navigation">
    <!-- Brand Logo Section -->
    <div class="nav-brand">
        <a href="/" class="brand-link">
            <div class="brand-logo">
                <span class="brand-icon">🌟</span>
                <span class="brand-text">SubashaVentures</span>
            </div>
        </a>
    </div>

    <!-- Right Side: Search + Burger -->
    <div class="nav-right">
        <!-- Search Bar -->
        <div class="nav-search">
            <div class="search-container">
                <input type="text"
                       class="search-input"
                       placeholder="Search products..."
                       @bind="searchQuery"
                       @onkeypress="HandleSearchKeyPress" />
                <button class="search-btn" @onclick="HandleSearch" title="Search">
                    🔍
                </button>
            </div>
        </div>

        <!-- Burger Menu -->
        <div class="burger-menu-wrapper">
            <input type="checkbox" id="ck-burger" @bind="isMobileMenuOpen" />
            <label for="ck-burger" class="burger-toggle">
                <div class="bar bar--top"></div>
                <div class="bar bar--middle"></div>
                <div class="bar bar--bottom"></div>
            </label>
        </div>
    </div>

    <!-- Dropdown Menu -->
    <div class="mobile-menu @(isMobileMenuOpen ? "active" : "")">
        <div class="mobile-menu-content">
            @if (isLoggedIn)
            {
            <!-- Logged in user menu -->
            <div class="user-info">
                <span class="user-name">@userName</span>
                <span class="user-email">@userEmail</span>
            </div>
            <hr class="dropdown-divider" />
            <a class="dropdown-item" href="/profile" @onclick="CloseMenu">
                My Profile
            </a>
            <a class="dropdown-item" href="/orders" @onclick="CloseMenu">
                My Orders
            </a>
            <a class="dropdown-item" href="/wishlist" @onclick="CloseMenu">
                Wishlist
            </a>
            <hr class="dropdown-divider" />
            <a class="dropdown-item" href="/" @onclick="CloseMenu">
                Home
            </a>
            <a class="dropdown-item" href="/shop" @onclick="CloseMenu">
                Shop
            </a>
            <a class="dropdown-item" href="/categories" @onclick="CloseMenu">
                Categories
            </a>
            <a class="dropdown-item" href="/about" @onclick="CloseMenu">
                About
            </a>
            <a class="dropdown-item" href="/contact" @onclick="CloseMenu">
                Contact
            </a>
            <hr class="dropdown-divider" />
            <button class="dropdown-item logout-btn" @onclick="HandleLogout">
                Sign Out
            </button>
            }
            else
            {
            <!-- Not logged in menu -->
            <div class="auth-section">
                <PrimaryButton Size="PrimaryButton.ButtonSize.Small" @onclick="() => NavigateToAuth(true)" class="auth-btn">
                    Sign In
                </PrimaryButton>
                <SecondaryButton Size="SecondaryButton.ButtonSize.Small" @onclick="() => NavigateToAuth(false)" class="auth-btn">
                    Sign Up
                </SecondaryButton>
            </div>
            <hr class="dropdown-divider" />
            <a class="dropdown-item" href="/" @onclick="CloseMenu">
                Home
            </a>
            <a class="dropdown-item" href="/shop" @onclick="CloseMenu">
                Shop
            </a>
            <a class="dropdown-item" href="/categories" @onclick="CloseMenu">
                Categories
            </a>
            <a class="dropdown-item" href="/about" @onclick="CloseMenu">
                About
            </a>
            <a class="dropdown-item" href="/contact" @onclick="CloseMenu">
                Contact
            </a>
            <hr class="dropdown-divider" />
            <a class="dropdown-item" href="/track-order" @onclick="CloseMenu">
                Track Order
            </a>
            <a class="dropdown-item" href="/help" @onclick="CloseMenu">
                Help
            </a>
            }
        </div>
    </div>
</nav>

@code {
private bool isMobileMenuOpen = false;
private string searchQuery = "";

// User state
private bool isLoggedIn = false; // Change this based on authentication
private string userName = "John Doe";
private string userEmail = "john.doe@example.com";

private void CloseMenu()
{
isMobileMenuOpen = false;
}

private void HandleSearch()
{
if (!string.IsNullOrWhiteSpace(searchQuery))
{
// Navigate to search results
// NavigationManager.NavigateTo($"/search?q={Uri.EscapeDataString(searchQuery)}");
}
}

private void HandleSearchKeyPress(KeyboardEventArgs e)
{
if (e.Key == "Enter")
{
HandleSearch();
}
}

private void NavigateToAuth(bool isSignIn)
{
CloseMenu();
if (isSignIn)
{
