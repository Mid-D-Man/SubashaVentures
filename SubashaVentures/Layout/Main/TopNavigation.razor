@using SubashaVentures.Components.Shared.Buttons

<nav class="top-navigation">
    <!-- Left: Brand Logo -->
    <div class="nav-left">
        <BrandLogo />
    </div>

    <!-- Middle: Filler Space -->
    <div class="nav-middle"></div>

    <!-- Right: Search + Burger -->
    <div class="nav-right">
        <!-- Search Bar -->
        <div class="nav-right-left">
            <div class="search-container">
                <span class="search-icon">🔍</span>
                <input type="text"
                       class="search-input"
                       placeholder="Search products..."
                       @bind="searchQuery"
                       @onkeypress="HandleSearchKeyPress" />
                <button class="search-clear @(string.IsNullOrEmpty(searchQuery) ? "hidden" : "")"
                        @onclick="ClearSearch"
                        title="Clear search">
                    ✕
                </button>
            </div>
        </div>

        <!-- Burger Menu -->
        <div class="nav-right-right">
            <div class="burger-menu-wrapper">
                <input type="checkbox" id="ck-burger" @bind="isMobileMenuOpen" />
                <label for="ck-burger" class="burger-toggle">
                    <div class="bar bar--top"></div>
                    <div class="bar bar--middle"></div>
                    <div class="bar bar--bottom"></div>
                </label>
            </div>
        </div>
    </div>

    <!-- Dropdown Menu -->
    <div class="dropdown-menu @(isMobileMenuOpen ? "active" : "")">
        <div class="dropdown-content">
            <!-- Navigation Section -->
            <div class="nav-section">
                <a class="dropdown-item" href="/" @onclick="CloseMenu">Home</a>
                <a class="dropdown-item" href="/shop" @onclick="CloseMenu">Shop</a>
                <a class="dropdown-item" href="/categories" @onclick="CloseMenu">Categories</a>
                <a class="dropdown-item" href="/about" @onclick="CloseMenu">About</a>
                <a class="dropdown-item" href="/contact" @onclick="CloseMenu">Contact</a>
                <a class="dropdown-item" href="/deals" @onclick="CloseMenu">Deals</a>
            </div>

            <!-- Separator Line -->
            <hr class="dropdown-separator" />

            <!-- Action Section -->
            <div class="action-section">
                @if (isLoggedIn)
                {
                    <div class="user-info">
                        <span class="user-name">@userName</span>
                        <span class="user-email">@userEmail</span>
                    </div>
                    <PrimaryButton Size="PrimaryButton.ButtonSize.Small" @onclick="() => NavigateTo(NavigationDestination.Profile)" class="action-btn">
                        My Profile
                    </PrimaryButton>
                    <SecondaryButton Size="SecondaryButton.ButtonSize.Small" @onclick="HandleLogout" class="action-btn">
                        Sign Out
                    </SecondaryButton>
                }
                else
                {
                    <PrimaryButton Size="PrimaryButton.ButtonSize.Small" @onclick="() => NavigateTo(NavigationDestination.SignIn)" class="action-btn">
                        Sign In
                    </PrimaryButton>
                }

                <SecondaryButton Size="SecondaryButton.ButtonSize.Small" @onclick="() => NavigateTo(NavigationDestination.TrackOrders)" class="action-btn">
                    Track Orders
                </SecondaryButton>
            </div>
        </div>
    </div>
</nav>

@code {
    private bool isMobileMenuOpen = false;
    private string searchQuery = "";

    // User state
    private bool isLoggedIn = false;
    private string userName = "John Doe";
    private string userEmail = "john.doe@example.com";

    // Enum for navigation destinations
    private enum NavigationDestination
    {
        SignIn,
        Profile,
        TrackOrders
    }

    private void CloseMenu()
    {
        isMobileMenuOpen = false;
    }

    private void ClearSearch()
    {
        searchQuery = "";
        StateHasChanged();
    }

    private void HandleSearchKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            HandleSearch();
        }
    }

    private void HandleSearch()
    {
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            // Navigate to search results
            // NavigationManager.NavigateTo($"/search?q={Uri.EscapeDataString(searchQuery)}");
        }
    }

    private void NavigateTo(NavigationDestination destination)
    {
        CloseMenu();

        string url = destination switch
        {
            NavigationDestination.SignIn => "/signin",
            NavigationDestination.Profile => "/profile",
            NavigationDestination.TrackOrders => "/track-order",
            _ => "/"
        };

        // NavigationManager.NavigateTo(url);
    }

    private async Task HandleLogout()
    {
        CloseMenu();
        isLoggedIn = false;
        userName = "";
        userEmail = "";
    }
}