@using SubashaVentures.Components.Shared.Buttons

<nav class="top-navigation">
    <!-- Brand Logo Section -->
    <div class="nav-brand">
        <a href="/" class="brand-link">
            <div class="brand-logo">
                <span class="brand-icon">🌟</span>
                <span class="brand-text">SubashaVentures</span>
            </div>
        </a>
    </div>

    <!-- Search Bar -->
    <div class="nav-search">
        <div class="search-container">
            <input type="text" 
                   class="search-input" 
                   placeholder="Search products..." 
                   @bind="searchQuery"
                   @onkeypress="HandleSearchKeyPress" />
            <button class="search-btn" @onclick="HandleSearch" title="Search">
                🔍
            </button>
        </div>
    </div>

    <!-- Right Side Actions -->
    <div class="nav-actions">
        <!-- Cart Button -->
        <button class="nav-action-btn cart-btn" @onclick="ToggleCart" title="Shopping Cart">
            <span class="btn-icon">🛒</span>
            <span class="cart-count">@cartItemCount</span>
        </button>

        <!-- User Menu Dropdown -->
        <div class="user-menu-wrapper">
            <button class="nav-action-btn user-btn" @onclick="ToggleUserMenu" title="Account">
                <span class="btn-icon">👤</span>
            </button>
            
            <!-- User Dropdown Menu -->
            <div class="user-dropdown @(isUserMenuOpen ? "active" : "")">
                <div class="user-dropdown-content">
                    @if (isLoggedIn)
                    {
                        <div class="user-info">
                            <span class="user-avatar">👤</span>
                            <div class="user-details">
                                <span class="user-name">@userName</span>
                                <span class="user-email">@userEmail</span>
                            </div>
                        </div>
                        <hr class="dropdown-divider" />
                        <a class="dropdown-item" href="/profile" @onclick="CloseUserMenu">
                            👤 My Profile
                        </a>
                        <a class="dropdown-item" href="/orders" @onclick="CloseUserMenu">
                            📦 My Orders
                        </a>
                        <a class="dropdown-item" href="/wishlist" @onclick="CloseUserMenu">
                            ❤️ Wishlist
                        </a>
                        <a class="dropdown-item" href="/settings" @onclick="CloseUserMenu">
                            ⚙️ Settings
                        </a>
                        <hr class="dropdown-divider" />
                        <button class="dropdown-item logout-btn" @onclick="HandleLogout">
                            🚪 Sign Out
                        </button>
                    }
                    else
                    {
                        <div class="auth-buttons">
                            <PrimaryButton Size="PrimaryButton.ButtonSize.Small" @onclick="() => NavigateToAuth(true)">
                                Sign In
                            </PrimaryButton>
                            <SecondaryButton Size="SecondaryButton.ButtonSize.Small" @onclick="() => NavigateToAuth(false)">
                                Sign Up
                            </SecondaryButton>
                        </div>
                        <hr class="dropdown-divider" />
                        <a class="dropdown-item" href="/guest-checkout" @onclick="CloseUserMenu">
                            🛒 Guest Checkout
                        </a>
                        <a class="dropdown-item" href="/track-order" @onclick="CloseUserMenu">
                            📍 Track Order
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Mobile Menu Burger -->
        <div class="burger-menu-wrapper">
            <input type="checkbox" id="ck-burger" @bind="isMobileMenuOpen" />
            <label for="ck-burger" class="burger-toggle">
                <div class="bar bar--top"></div>
                <div class="bar bar--middle"></div>
                <div class="bar bar--bottom"></div>
            </label>
        </div>
    </div>

    <!-- Mobile Menu Dropdown -->
    <div class="mobile-menu @(isMobileMenuOpen ? "active" : "")">
        <div class="mobile-menu-content">
            <!-- Mobile Search -->
            <div class="mobile-search">
                <div class="search-container">
                    <input type="text" 
                           class="search-input" 
                           placeholder="Search products..." 
                           @bind="mobileSearchQuery"
                           @onkeypress="HandleMobileSearchKeyPress" />
                    <button class="search-btn" @onclick="HandleMobileSearch" title="Search">
                        🔍
                    </button>
                </div>
            </div>
            
            <!-- Mobile Navigation Links -->
            <div class="mobile-nav-links">
                <a class="mobile-nav-item" href="/" @onclick="CloseMobileMenu">
                    <span class="nav-icon">🏠</span>
                    <span class="mobile-nav-text">Home</span>
                </a>
                <a class="mobile-nav-item" href="/shop" @onclick="CloseMobileMenu">
                    <span class="nav-icon">🛍️</span>
                    <span class="mobile-nav-text">Shop</span>
                </a>
                <a class="mobile-nav-item" href="/categories" @onclick="CloseMobileMenu">
                    <span class="nav-icon">📂</span>
                    <span class="mobile-nav-text">Categories</span>
                </a>
                <a class="mobile-nav-item" href="/deals" @onclick="CloseMobileMenu">
                    <span class="nav-icon">💰</span>
                    <span class="mobile-nav-text">Deals</span>
                </a>
                <a class="mobile-nav-item" href="/about" @onclick="CloseMobileMenu">
                    <span class="nav-icon">ℹ️</span>
                    <span class="mobile-nav-text">About</span>
                </a>
                <a class="mobile-nav-item" href="/contact" @onclick="CloseMobileMenu">
                    <span class="nav-icon">📞</span>
                    <span class="mobile-nav-text">Contact</span>
                </a>
            </div>
        </div>
    </div>
</nav>

