@* Pages/Main/OurStory.razor *@
@page "/our-story"
@using SubashaVentures.Utilities.Constants
@using SubashaVentures.Components.Shared.Buttons
@layout SubashaVentures.Layout.Main.LandingPageLayout

<div class="our-story-page">

    <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
    <section class="os-hero">
        <div class="os-hero-noise"></div>
        <div class="os-hero-overlay"></div>
        <div class="os-hero-content">
            <span class="os-eyebrow">Our Story</span>
            <h1 class="os-hero-headline">
                <span class="os-headline-line os-hl-1">@SiteConfig.StoryHeroHeadline</span>
                <em class="os-headline-line os-hl-2">@SiteConfig.StoryHeroAccent</em>
            </h1>
            <p class="os-hero-sub">@SiteConfig.StoryHeroSub</p>
            <div class="os-scroll-hint" aria-hidden="true">
                <span class="os-scroll-label">Scroll to discover</span>
                <div class="os-scroll-line"></div>
            </div>
        </div>

        <!-- decorative floating shapes -->
        <div class="os-hero-shape os-shape-1" aria-hidden="true"></div>
        <div class="os-hero-shape os-shape-2" aria-hidden="true"></div>
        <div class="os-hero-shape os-shape-3" aria-hidden="true"></div>
    </section>

    <!-- ══════════════════════════════ ORIGIN ══════════════════════════════ -->
    <section class="os-origin">
        <div class="os-container">
            <div class="os-origin-grid">
                <div class="os-origin-text reveal-left">
                    <span class="os-label">@SiteConfig.StoryOriginLabel</span>
                    <h2 class="os-section-h2">@SiteConfig.StoryOriginHeading</h2>
                    <p>@SiteConfig.StoryOriginPara1</p>
                    <p>@SiteConfig.StoryOriginPara2</p>
                </div>
                <div class="os-origin-visual reveal-right">
                    <div class="os-origin-card">
                        <div class="os-origin-card-year">@SiteConfig.FoundedYear</div>
                        <div class="os-origin-card-label">Founded in Lagos</div>
                        <div class="os-origin-card-divider"></div>
                        <div class="os-origin-card-items">
                            <div class="os-origin-card-item">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 6L9 17l-5-5"/>
                                </svg>
                                <span>50 handpicked products</span>
                            </div>
                            <div class="os-origin-card-item">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 6L9 17l-5-5"/>
                                </svg>
                                <span>Every item personally tested</span>
                            </div>
                            <div class="os-origin-card-item">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 6L9 17l-5-5"/>
                                </svg>
                                <span>Zero compromises on quality</span>
                            </div>
                        </div>
                    </div>
                    <!-- decorative dot grid -->
                    <div class="os-dot-grid" aria-hidden="true">
                        @for (int i = 0; i < 25; i++)
                        {
                            <div class="os-dot"></div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ════════════════════════════ NUMBERS BAR ═══════════════════════════ -->
    <section class="os-numbers">
        <div class="os-container">
            <div class="os-numbers-grid reveal-up">
                <div class="os-number-item">
                    <div class="os-number-val">10K<span>+</span></div>
                    <div class="os-number-label">Happy Customers</div>
                </div>
                <div class="os-number-divider" aria-hidden="true"></div>
                <div class="os-number-item">
                    <div class="os-number-val">5K<span>+</span></div>
                    <div class="os-number-label">Products Available</div>
                </div>
                <div class="os-number-divider" aria-hidden="true"></div>
                <div class="os-number-item">
                    <div class="os-number-val">36<span></span></div>
                    <div class="os-number-label">States Delivered To</div>
                </div>
                <div class="os-number-divider" aria-hidden="true"></div>
                <div class="os-number-item">
                    <div class="os-number-val">8K<span>+</span></div>
                    <div class="os-number-label">Orders Delivered</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════ TIMELINE ════════════════════════════ -->
    <section class="os-timeline">
        <div class="os-container">
            <div class="os-section-header reveal-up">
                <span class="os-label">How We Got Here</span>
                <h2 class="os-section-h2">Our Journey</h2>
            </div>

            <div class="os-timeline-track">
                <div class="os-timeline-line" aria-hidden="true"></div>

                <div class="os-tl-item os-tl-left reveal-left">
                    <div class="os-tl-content">
                        <span class="os-tl-date">Early 2022</span>
                        <h3 class="os-tl-heading">The Spark</h3>
                        <p class="os-tl-text">Two people in a Lagos apartment, frustrated by the same problem every Nigerian shopper faces — poor quality at premium prices. The decision was made: we'd fix it ourselves.</p>
                    </div>
                    <div class="os-tl-dot" aria-hidden="true"></div>
                </div>

                <div class="os-tl-item os-tl-right reveal-right">
                    <div class="os-tl-dot" aria-hidden="true"></div>
                    <div class="os-tl-content">
                        <span class="os-tl-date">Mid 2022</span>
                        <h3 class="os-tl-heading">First 100 Orders</h3>
                        <p class="os-tl-text">Every single package hand-packed. Every customer emailed personally. We knew their names. That personal touch became our foundation — and we've never lost it.</p>
                    </div>
                </div>

                <div class="os-tl-item os-tl-left reveal-left">
                    <div class="os-tl-content">
                        <span class="os-tl-date">2023</span>
                        <h3 class="os-tl-heading">Going National</h3>
                        <p class="os-tl-text">Delivery to all 36 states. From Sokoto to Calabar, from Maiduguri to Lagos Island — Subasha quality reached every corner of Nigeria. No exclusions, no extra charges for "distant" locations.</p>
                    </div>
                    <div class="os-tl-dot" aria-hidden="true"></div>
                </div>

                <div class="os-tl-item os-tl-right reveal-right">
                    <div class="os-tl-dot" aria-hidden="true"></div>
                    <div class="os-tl-content">
                        <span class="os-tl-date">Late 2023</span>
                        <h3 class="os-tl-heading">Home &amp; Living</h3>
                        <p class="os-tl-text">Nigerian homes deserved the same quality upgrade as Nigerian wardrobes. We expanded into home goods — bedding, décor, kitchen essentials — with the same uncompromising standard.</p>
                    </div>
                </div>

                <div class="os-tl-item os-tl-left reveal-left">
                    <div class="os-tl-content">
                        <span class="os-tl-date">2024</span>
                        <h3 class="os-tl-heading">10,000 Customers</h3>
                        <p class="os-tl-text">A milestone we celebrated quietly — not with a marketing campaign, but by reaching out personally to say thank you. Our customers didn't find us; they built us.</p>
                    </div>
                    <div class="os-tl-dot" aria-hidden="true"></div>
                </div>

                <div class="os-tl-item os-tl-right reveal-right">
                    <div class="os-tl-dot" aria-hidden="true"></div>
                    <div class="os-tl-content">
                        <span class="os-tl-date">Now</span>
                        <h3 class="os-tl-heading">Still Building</h3>
                        <p class="os-tl-text">5,000+ products. 8,000+ deliveries. A community that keeps growing. The apartment is gone, but the standard it set? That's everywhere we look.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════ VALUES ══════════════════════════════ -->
    <section class="os-values">
        <div class="os-container">
            <div class="os-section-header reveal-up">
                <span class="os-label">What Drives Us</span>
                <h2 class="os-section-h2">What We Stand For</h2>
            </div>
            <div class="os-values-grid">

                <div class="os-value-card reveal-up" style="--delay:0ms">
                    <div class="os-value-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                        </svg>
                    </div>
                    <h3 class="os-value-heading">Quality is Non-Negotiable</h3>
                    <p class="os-value-text">Every item on Subasha has been evaluated — fabric weight, stitching strength, colourfastness. If it doesn't hold up, it doesn't go up.</p>
                </div>

                <div class="os-value-card reveal-up" style="--delay:120ms">
                    <div class="os-value-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                    </div>
                    <h3 class="os-value-heading">Honest Pricing</h3>
                    <p class="os-value-text">No inflated markups, no manufactured urgency, no hidden delivery fees. You see the price. You pay the price. That's it.</p>
                </div>

                <div class="os-value-card reveal-up" style="--delay:240ms">
                    <div class="os-value-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                    </div>
                    <h3 class="os-value-heading">Nigerian at Heart</h3>
                    <p class="os-value-text">We don't just sell to Nigerians — we celebrate Nigerian identity in every collection, every design choice, every campaign. This is for us, by us.</p>
                </div>

                <div class="os-value-card reveal-up" style="--delay:360ms">
                    <div class="os-value-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </div>
                    <h3 class="os-value-heading">You Come First</h3>
                    <p class="os-value-text">Customer obsession isn't a policy pinned to a wall here — it's the reason every person at Subasha comes to work. Your experience is our report card.</p>
                </div>

            </div>
        </div>
    </section>

    <!-- ═══════════════════════════ MISSION QUOTE ══════════════════════════ -->
    <section class="os-mission">
        <div class="os-mission-inner reveal-up">
            <div class="os-mission-mark" aria-hidden="true">"</div>
            <blockquote class="os-mission-quote">
                @SiteConfig.StoryMissionQuote
            </blockquote>
            <cite class="os-mission-cite">— The Subasha Team</cite>
        </div>
    </section>

    <!-- ════════════════════════════════ CTA ═══════════════════════════════ -->
    <section class="os-cta">
        <div class="os-cta-inner reveal-up">
            <h2 class="os-cta-heading">@SiteConfig.StoryCtaHeading</h2>
            <p class="os-cta-sub">@SiteConfig.StoryCtaSub</p>
            <button class="os-cta-btn" @onclick="NavigateToShop">
                <span>Shop Now</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </button>
        </div>
    </section>

</div>
