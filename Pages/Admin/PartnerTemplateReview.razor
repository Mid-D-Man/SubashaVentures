@page "/admin/partner-templates"
@using SubashaVentures.Layout.Admin
@using SubashaVentures.Components.Shared.Buttons
@using SubashaVentures.Components.Shared.Forms
@using SubashaVentures.Components.Shared.Modals
@using SubashaVentures.Components.Shared.Notifications
@using SubashaVentures.Domain.Partner
@using SubashaVentures.Models.Supabase
@layout AdminLayout

<div class="partner-template-review">

    <NotificationComponent @ref="notificationComponent"
                           Position="NotificationPosition.TopRight"
                           AutoDismissTime="5000" />

    <!-- Header -->
    <div class="ptr-header">
        <div class="ptr-header-left">
            <h1 class="ptr-title">Partner Template Review</h1>
            <p class="ptr-subtitle">Review and approve or reject partner product submissions.</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="ptr-stats">
        <div class="ptr-stat-card">
            <span class="ptr-stat-value">@stats.TotalTemplates</span>
            <span class="ptr-stat-label">Total</span>
        </div>
        <div class="ptr-stat-card pending">
            <span class="ptr-stat-value">@stats.PendingReview</span>
            <span class="ptr-stat-label">Pending Review</span>
        </div>
        <div class="ptr-stat-card approved">
            <span class="ptr-stat-value">@stats.Approved</span>
            <span class="ptr-stat-label">Approved</span>
        </div>
        <div class="ptr-stat-card rejected">
            <span class="ptr-stat-value">@stats.Rejected</span>
            <span class="ptr-stat-label">Rejected</span>
        </div>
        <div class="ptr-stat-card draft">
            <span class="ptr-stat-value">@stats.Drafts</span>
            <span class="ptr-stat-label">Drafts</span>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="ptr-toolbar">
        <div class="ptr-filters">
            <InputField Value="@searchQuery"
                        ValueChanged="@((v) => { searchQuery = v; ApplyFilter(); })"
                        Placeholder="Search product name, partner..."
                        PrefixIcon="search"
                        ShowClearButton="true"
                        CssClass="ptr-search" />

            <select class="ptr-select" @onchange="HandleStatusFilter">
                <option value="">All Status</option>
                <option value="pending_review">Pending Review</option>
                <option value="approved">Approved</option>
                <option value="rejected">Rejected</option>
                <option value="draft">Draft</option>
            </select>

            <select class="ptr-select" @onchange="HandleSortChange">
                <option value="newest">Newest First</option>
                <option value="oldest">Oldest First</option>
                <option value="submitted">Submitted First</option>
            </select>
        </div>
    </div>

    <!-- Content -->
    @if (isLoading)
    {
        <div class="ptr-loading">
            <div class="ptr-spinner"></div>
            <p>Loading templates...</p>
        </div>
    }
    else if (!filtered.Any())
    {
        <div class="ptr-empty">
            <div class="ptr-empty-icon">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M3 9H21M9 21V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            </div>
            <h3>No templates found</h3>
            <p>@(string.IsNullOrEmpty(searchQuery) && string.IsNullOrEmpty(selectedStatus)
                ? "No partner product templates have been submitted yet."
                : "Try adjusting your filters.")</p>
        </div>
    }
    else
    {
        <div class="ptr-grid">
            @foreach (var template in filtered)
            {
                <div class="ptr-card @(selectedTemplate?.Id == template.Id ? "selected" : "")"
                     @onclick="@(() => SelectTemplate(template))">

                    <div class="ptr-card-thumb">
                        @if (!string.IsNullOrEmpty(template.ThumbnailUrl))
                        {
                            <img src="@template.ThumbnailUrl" alt="@template.ProductName" />
                        }
                        else
                        {
                            <div class="ptr-thumb-placeholder">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                                    <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M3 16L8 11L11 14L15 10L21 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    <circle cx="8.5" cy="8.5" r="1.5" stroke="currentColor" stroke-width="1.5"/>
                                </svg>
                            </div>
                        }
                        <span class="ptr-status-badge @template.StatusBadgeClass">
                            @template.StatusDisplay
                        </span>
                    </div>

                    <div class="ptr-card-body">
                        <h3 class="ptr-card-name">@template.ProductName</h3>
                        <p class="ptr-card-template">@template.TemplateName</p>
                        <div class="ptr-card-meta">
                            <span class="ptr-card-price">@template.DisplayProposedPrice</span>
                            <span class="ptr-card-category">@template.CategoryName</span>
                        </div>
                        <div class="ptr-card-variants">
                            @template.Variants.Count variant(s) · @template.TotalStock units
                        </div>
                        @if (template.SubmittedAt.HasValue)
                        {
                            <div class="ptr-card-submitted">
                                Submitted @template.SubmittedAtDisplay
                            </div>
                        }
                        @if (template.HasPriceOverride)
                        {
                            <div class="ptr-price-override">
                                Admin price: @template.DisplayEffectivePrice
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Detail Modal -->
<DynamicModal @ref="detailModal"
              Title="Template Detail"
              Size="DynamicModal.ModalSize.Large"
              IsOpen="@isDetailOpen"
              ShowFooter="false"
              IsScrollable="true"
              OnClose="CloseDetail">
    <BodyContent>
        @if (selectedTemplate != null)
        {
            <div class="ptr-detail">

                <div class="ptr-detail-status @selectedTemplate.StatusBadgeClass">
                    @selectedTemplate.StatusDisplay
                </div>

                <!-- Images -->
                @if (selectedTemplate.ImageUrls.Any())
                {
                    <div class="ptr-detail-images">
                        @foreach (var url in selectedTemplate.ImageUrls)
                        {
                            <img src="@url" alt="Product image" class="ptr-detail-img" />
                        }
                    </div>
                }

                <!-- Product Info -->
                <div class="ptr-detail-section">
                    <h3>Product Information</h3>
                    <div class="ptr-detail-grid">
                        <div class="ptr-detail-item">
                            <span class="detail-label">Product Name</span>
                            <span class="detail-value">@selectedTemplate.ProductName</span>
                        </div>
                        <div class="ptr-detail-item">
                            <span class="detail-label">Template Name</span>
                            <span class="detail-value">@selectedTemplate.TemplateName</span>
                        </div>
                        <div class="ptr-detail-item">
                            <span class="detail-label">Category</span>
                            <span class="detail-value">@selectedTemplate.CategoryName</span>
                        </div>
                        <div class="ptr-detail-item">
                            <span class="detail-label">Proposed Price</span>
                            <span class="detail-value">@selectedTemplate.DisplayProposedPrice</span>
                        </div>
                        @if (selectedTemplate.ProposedOriginalPrice.HasValue)
                        {
                            <div class="ptr-detail-item">
                                <span class="detail-label">Original Price</span>
                                <span class="detail-value">₦@selectedTemplate.ProposedOriginalPrice.Value.ToString("N0")</span>
                            </div>
                        }
                        <div class="ptr-detail-item">
                            <span class="detail-label">Weight (kg)</span>
                            <span class="detail-value">@selectedTemplate.WeightKg kg</span>
                        </div>
                        <div class="ptr-detail-item">
                            <span class="detail-label">Free Shipping</span>
                            <span class="detail-value">@(selectedTemplate.HasFreeShipping ? "Yes" : "No")</span>
                        </div>
                        <div class="ptr-detail-item">
                            <span class="detail-label">Tags</span>
                            <span class="detail-value">
                                @(selectedTemplate.Tags.Any()
                                    ? string.Join(", ", selectedTemplate.Tags)
                                    : "None")
                            </span>
                        </div>
                    </div>
                    <div class="ptr-detail-desc">
                        <span class="detail-label">Description</span>
                        <p>@selectedTemplate.Description</p>
                    </div>
                </div>

                <!-- Variants -->
                <div class="ptr-detail-section">
                    <h3>Variants (@selectedTemplate.Variants.Count)</h3>
                    <div class="ptr-variants-table">
                        <div class="ptr-variants-header">
                            <span>SKU</span>
                            <span>Size</span>
                            <span>Color</span>
                            <span>Stock</span>
                            <span>Price Adj</span>
                        </div>
                        @foreach (var v in selectedTemplate.Variants)
                        {
                            <div class="ptr-variants-row">
                                <span class="variant-sku">@v.Sku</span>
                                <span>@(v.Size ?? "—")</span>
                                <span>@(v.Color ?? "—")</span>
                                <span>@v.Stock</span>
                                <span>@v.DisplayPriceAdjustment</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Rejection History -->
                @if (selectedTemplate.RejectionHistory.Any())
                {
                    <div class="ptr-detail-section">
                        <h3>Rejection History (@selectedTemplate.RejectionHistory.Count)</h3>
                        @foreach (var r in selectedTemplate.RejectionHistory.OrderByDescending(x => x.RejectedAt))
                        {
                            <div class="ptr-rejection-entry">
                                <div class="ptr-rejection-header">
                                    <span class="rejection-date">@r.RejectedAtDisplay</span>
                                    <span class="rejection-by">by @r.RejectedBy</span>
                                </div>
                                <p class="rejection-reason">@r.Reason</p>
                                @if (r.FieldsFlagged.Any())
                                {
                                    <div class="rejection-fields">
                                        Fields flagged: @string.Join(", ", r.FieldsFlagged)
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Actions -->
                @if (selectedTemplate.IsPendingReview)
                {
                    <div class="ptr-detail-actions">
                        <div class="ptr-price-override-group">
                            <label class="detail-label">
                                Price Override (₦) — leave blank to use proposed price
                            </label>
                            <input type="number"
                                   class="ptr-input"
                                   @bind="priceOverride"
                                   placeholder="@selectedTemplate.ProposedPrice"
                                   min="0"
                                   step="100" />
                        </div>

                        <div class="ptr-action-buttons">
                            <PrimaryButton OnClick="HandleApprove"
                                          IsLoading="@isActioning"
                                          IsDisabled="@isActioning">
                                Approve Template
                            </PrimaryButton>
                            <SecondaryButton Variant="SecondaryButton.ButtonVariant.Outline"
                                            OnClick="OpenRejectModal"
                                            CssClass="btn-danger-outline">
                                Reject
                            </SecondaryButton>
                        </div>
                    </div>
                }
            </div>
        }
    </BodyContent>
</DynamicModal>

<!-- Reject Modal -->
<DynamicModal @ref="rejectModal"
              Title="Reject Template"
              Size="DynamicModal.ModalSize.Medium"
              IsOpen="@isRejectOpen"
              ShowFooter="false"
              OnClose="CloseRejectModal">
    <BodyContent>
        <div class="ptr-reject-form">

            <div class="ptr-reject-warning">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                    <path d="M12 9V11M12 15H12.01M5.07183 19H18.9282C20.4678 19 21.4301 17.3333 20.6603 16L13.7321 4C12.9623 2.66667 11.0378 2.66667 10.268 4L3.33978 16C2.56998 17.3333 3.53223 19 5.07183 19Z"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <p>
                    Rejecting <strong>@selectedTemplate?.ProductName</strong>.
                    The partner will be able to edit and resubmit.
                </p>
            </div>

            <div class="form-group">
                <label class="form-label">
                    Rejection Reason <span class="required">*</span>
                </label>
                <textarea class="form-textarea @(HasRejectError("Reason") ? "has-error" : "")"
                          @bind="rejectForm.Reason"
                          placeholder="Explain clearly why the template is being rejected."
                          rows="4"></textarea>
                @if (HasRejectError("Reason"))
                {
                    <span class="error-text">@GetRejectError("Reason")</span>
                }
            </div>

            <div class="form-group">
                <label class="form-label">Fields to Flag (optional)</label>
                <input type="text"
                       class="form-input"
                       @bind="rejectForm.FieldsFlaggedInput"
                       placeholder="e.g. description, price, images (comma separated)" />
            </div>

            <div class="form-group">
                <label class="form-label">Admin Notes (internal only)</label>
                <textarea class="form-textarea"
                          @bind="rejectForm.AdminNotes"
                          placeholder="Private notes visible only to admins"
                          rows="2"></textarea>
            </div>

            <div class="reject-form-actions">
                <SecondaryButton Variant="SecondaryButton.ButtonVariant.Outline"
                                OnClick="CloseRejectModal">
                    Cancel
                </SecondaryButton>
                <PrimaryButton OnClick="HandleConfirmReject"
                              IsLoading="@isActioning"
                              IsDisabled="@isActioning"
                              CssClass="btn-danger">
                    Confirm Rejection
                </PrimaryButton>
            </div>
        </div>
    </BodyContent>
</DynamicModal>
