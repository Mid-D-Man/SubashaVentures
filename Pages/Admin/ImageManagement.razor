@* Pages/Admin/ImageManagement.razor *@
@page "/admin/images"
@using SubashaVentures.Layout.Admin
@using SubashaVentures.Components.Shared.Buttons
@using SubashaVentures.Components.Shared.Forms
@using SubashaVentures.Components.Shared.Modals
@using SubashaVentures.Components.Admin.Images
@using SubashaVentures.Components.Shared.Notifications
@layout AdminLayout

<div class="image-management">

    <!-- ── Header ── -->
    <div class="im-header">
        <div class="im-header-left">
            <h1 class="im-title">Image Management</h1>
            <p class="im-subtitle">Upload and manage product images</p>
        </div>
        <div class="im-header-right">
            <PrimaryButton Variant="PrimaryButton.ButtonVariant.Primary"
                           Size="PrimaryButton.ButtonSize.Medium"
                           Icon="⬆"
                           OnClick="OpenUploadModal">
                Upload Images
            </PrimaryButton>
        </div>
    </div>

    <!-- ── Storage Stats ── -->
    <div class="im-stats">
        <div class="stat-card storage">
            <div class="stat-header">
                <span class="stat-label">Storage Used</span>
                <span class="stat-icon">💾</span>
            </div>
            <div class="stat-body">
                <div class="storage-bar">
                    <div class="storage-fill" style="width: @storagePercentage%"></div>
                </div>
                <div class="storage-info">
                    <span class="used">@usedStorage</span>
                    <span class="total">of @totalStorage</span>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">🖼️</div>
            <div class="stat-info">
                <span class="stat-label">Total Images</span>
                <span class="stat-value">@totalImages</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">📂</div>
            <div class="stat-info">
                <span class="stat-label">Categories</span>
                <span class="stat-value">@totalFolders</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">🔗</div>
            <div class="stat-info">
                <span class="stat-label">Referenced</span>
                <span class="stat-value">@referencedImages</span>
            </div>
        </div>
    </div>

    <!-- ── Toolbar ── -->
    <div class="im-toolbar">
        <div class="im-filters">
            <select class="filter-select folder-select" @onchange="HandleFolderFilterChange">
                <option value="">All Folders</option>
                @foreach (var category in categories.Where(c => c.IsActive).OrderBy(c => c.DisplayOrder))
                {
                    <option value="@category.Slug">@category.Name</option>
                }
            </select>

            <div class="search-box-wrapper">
                <svg class="search-icon-inline" width="16" height="16" viewBox="0 0 24 24" fill="none">
                    <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
                    <path d="M21 21L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <input class="search-input-native"
                       type="text"
                       placeholder="Search images…"
                       value="@searchQuery"
                       @oninput="HandleSearchInput" />
                @if (!string.IsNullOrEmpty(searchQuery))
                {
                    <button class="search-clear-btn" @onclick="ClearSearch">×</button>
                }
            </div>

            <select class="filter-select" @onchange="HandleSortChange">
                <option value="newest">Newest First</option>
                <option value="oldest">Oldest First</option>
                <option value="name-az">Name (A-Z)</option>
                <option value="name-za">Name (Z-A)</option>
                <option value="size-largest">Largest First</option>
                <option value="size-smallest">Smallest First</option>
            </select>
        </div>

        <div class="im-view-controls">
            @if (selectedImages.Any())
            {
                <span class="selection-count">@selectedImages.Count selected</span>
                <SecondaryButton Size="SecondaryButton.ButtonSize.Small"
                                 Variant="SecondaryButton.ButtonVariant.Outline"
                                 OnClick="HandleBulkDownload">
                    ⬇ Download
                </SecondaryButton>
                <SecondaryButton Size="SecondaryButton.ButtonSize.Small"
                                 Variant="SecondaryButton.ButtonVariant.Outline"
                                 OnClick="HandleBulkDelete"
                                 CssClass="btn-danger-outline">
                    🗑 Delete
                </SecondaryButton>
            }

            <button class="view-toggle @(gridSize == "small"  ? "active" : "")"
                    @onclick="@(() => SetGridSize("small"))">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                    <rect x="0" y="0" width="6" height="6" rx="1"/>
                    <rect x="10" y="0" width="6" height="6" rx="1"/>
                    <rect x="0" y="10" width="6" height="6" rx="1"/>
                    <rect x="10" y="10" width="6" height="6" rx="1"/>
                </svg>
            </button>
            <button class="view-toggle @(gridSize == "medium" ? "active" : "")"
                    @onclick="@(() => SetGridSize("medium"))">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                    <rect x="0" y="0" width="7" height="7" rx="1"/>
                    <rect x="9" y="0" width="7" height="7" rx="1"/>
                    <rect x="0" y="9" width="7" height="7" rx="1"/>
                    <rect x="9" y="9" width="7" height="7" rx="1"/>
                </svg>
            </button>
            <button class="view-toggle @(gridSize == "large"  ? "active" : "")"
                    @onclick="@(() => SetGridSize("large"))">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
                    <rect x="0" y="0" width="16" height="7" rx="1"/>
                    <rect x="0" y="9" width="16" height="7" rx="1"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- ── Batch progress bar (only during loading-more) ── -->
    @if (isLoadingMore)
    {
        <div class="im-batch-progress">
            <div class="im-batch-bar">
                <div class="im-batch-fill" style="width: @loadingProgress%"></div>
            </div>
            <span class="im-batch-label">
                Loading @loadedFolderCount / @totalFolderCount categories…
            </span>
        </div>
    }

    <!-- ── Main content area ── -->
    @if (isLoading && !allImages.Any())
    {
        <div class="im-loading">
            <div class="loading-spinner"></div>
            <p>Loading images…</p>
            @if (totalFolderCount > 0)
            {
                <div class="im-batch-progress" style="width:260px;margin-top:0.5rem;">
                    <div class="im-batch-bar">
                        <div class="im-batch-fill" style="width: @loadingProgress%"></div>
                    </div>
                    <span class="im-batch-label">@loadedFolderCount / @totalFolderCount categories</span>
                </div>
            }
        </div>
    }
    else if (!filteredImages.Any() && !isLoading && !isLoadingMore)
    {
        <div class="im-empty">
            <div class="empty-icon">🖼️</div>
            <h3>No images found</h3>
            <p>@(string.IsNullOrEmpty(searchQuery) && string.IsNullOrEmpty(selectedFolder)
                ? "Upload your first image to get started"
                : "No images match your filters")</p>
            @if (!string.IsNullOrEmpty(searchQuery) || !string.IsNullOrEmpty(selectedFolder))
            {
                <SecondaryButton Variant="SecondaryButton.ButtonVariant.Outline"
                                 OnClick="ClearAllFilters"
                                 Size="SecondaryButton.ButtonSize.Small">
                    Clear Filters
                </SecondaryButton>
            }
            else
            {
                <PrimaryButton OnClick="OpenUploadModal">Upload Images</PrimaryButton>
            }
        </div>
    }
    else
    {
        <!-- Results count bar -->
        <div class="im-results-bar">
            <span class="im-results-count">
                @if (HasActiveFilters)
                {
                    @($"{filteredImages.Count} of {allImages.Count} images")
                }
                else
                {
                    @($"{allImages.Count} image{(allImages.Count != 1 ? "s" : "")}")
                }
            </span>
            @if (HasActiveFilters)
            {
                <button class="im-reset-filters-btn" @onclick="ClearAllFilters">
                    Reset filters
                </button>
            }
        </div>

        <!-- Image Grid -->
        <div class="im-grid @gridSize">
            @foreach (var image in paginatedImages)
            {
                <AdminImageCard Image="@image"
                                IsSelected="@selectedImages.Contains(image.Id)"
                                OnCopyUrl="HandleCopyUrl"
                                OnDownload="HandleDownload"
                                OnDelete="HandleDelete"
                                OnConvert="HandleConvert"
                                OnMove="HandleMove"
                                OnSelectionChanged="@((args) => HandleImageSelect(args.imageId, args.isSelected))" />
            }

            @if (isLoadingMore)
            {
                @for (int i = 0; i < 6; i++)
                {
                    <div class="im-skeleton-card">
                        <div class="im-skeleton-img"></div>
                        <div class="im-skeleton-info">
                            <div class="im-skeleton-line"></div>
                            <div class="im-skeleton-line short"></div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- ── Pagination — sticky bottom ── -->
        @if (totalPages > 0)
        {
            <div class="im-pagination">
                <div class="pagination-info">
                    Showing @((currentPage - 1) * pageSize + 1)–@Math.Min(currentPage * pageSize, filteredImages.Count)
                    of @filteredImages.Count images
                </div>
                <div class="pagination-controls">
                    <button class="page-btn prev-next"
                            @onclick="PreviousPage"
                            disabled="@(currentPage <= 1)">
                        ← Prev
                    </button>

                    @{
                        var startPage = Math.Max(1, currentPage - 2);
                        var endPage   = Math.Min(totalPages, currentPage + 2);

                        if (startPage > 1)
                        {
                            <button class="page-btn" @onclick="@(() => GoToPage(1))">1</button>
                            if (startPage > 2) { <span class="page-ellipsis">…</span> }
                        }

                        for (int pg = startPage; pg <= endPage; pg++)
                        {
                            var pageCapture = pg;
                            <button class="page-btn @(pageCapture == currentPage ? "active" : "")"
                                    @onclick="@(() => GoToPage(pageCapture))">
                                @pageCapture
                            </button>
                        }

                        if (endPage < totalPages)
                        {
                            if (endPage < totalPages - 1) { <span class="page-ellipsis">…</span> }
                            <button class="page-btn" @onclick="@(() => GoToPage(totalPages))">@totalPages</button>
                        }
                    }

                    <button class="page-btn prev-next"
                            @onclick="NextPage"
                            disabled="@(currentPage >= totalPages)">
                        Next →
                    </button>
                </div>
                <div class="pagination-size">
                    <label>Per page:</label>
                    <select @onchange="HandlePageSizeChange" class="page-size-select">
                        <option value="12"  selected="@(pageSize == 12)">12</option>
                        <option value="24"  selected="@(pageSize == 24)">24</option>
                        <option value="48"  selected="@(pageSize == 48)">48</option>
                        <option value="96"  selected="@(pageSize == 96)">96</option>
                    </select>
                </div>
            </div>
        }
    }
</div>

<!-- ══ Upload Modal ══ -->
<DynamicModal @ref="uploadModal"
              Title="Upload Images"
              Size="DynamicModal.ModalSize.Large"
              IsOpen="@isUploadModalOpen"
              ShowFooter="false"
              OnClose="CloseUploadModal">
    <BodyContent>
        <div class="upload-modal-content">
            <div class="upload-section">
                <label class="upload-label">Upload to Category</label>
                <select class="upload-select" @bind="uploadFolder">
                    @foreach (var category in categories.Where(c => c.IsActive).OrderBy(c => c.DisplayOrder))
                    {
                        <option value="@category.Slug">@category.Name</option>
                    }
                </select>
            </div>

            <div class="upload-section">
                <label class="compression-toggle">
                    <input type="checkbox" @bind="enableCompression" class="compression-checkbox" />
                    <span class="compression-label">Enable Image Compression + WebP Conversion (Recommended)</span>
                    <span class="compression-hint">Reduces file size 25–34% while maintaining quality</span>
                </label>
            </div>

            <div class="upload-dropzone-wrapper"
                 @ondragover:preventDefault="true"
                 @ondragenter:preventDefault="true"
                 @ondrop="HandleDrop"
                 @ondragenter="HandleDragEnter"
                 @ondragleave="HandleDragLeave">
                <InputFile OnChange="HandleFileSelect"
                           multiple
                           accept="image/*"
                           id="imageUploadInput"
                           class="file-input-native" />
                <label for="imageUploadInput"
                       class="upload-dropzone @(isDragging ? "dragging" : "")">
                    <div class="dropzone-content">
                        <div class="dropzone-icon">📁</div>
                        <h3>Drag & drop images here</h3>
                        <p>or</p>
                        <div class="browse-btn-wrapper">
                            <span class="browse-btn">Browse Files</span>
                        </div>
                        <p class="upload-hint">Supports: JPG, PNG, WebP, GIF (Max 50 MB)</p>
                    </div>
                </label>
            </div>

            @if (uploadQueue.Any())
            {
                <div class="upload-queue">
                    <div class="queue-header">
                        <h4>Upload Queue (@uploadQueue.Count files)</h4>
                        <button class="clear-queue" @onclick="ClearQueue" type="button">Clear All</button>
                    </div>

                    @foreach (var item in uploadQueue)
                    {
                        <div class="queue-item @item.Status">
                            <div class="queue-preview">
                                <img src="@item.PreviewUrl" alt="@item.FileName" />
                            </div>
                            <div class="queue-info">
                                <span class="queue-name">@item.FileName</span>
                                <span class="queue-size">@item.FormattedSize</span>
                                @if (!string.IsNullOrEmpty(item.ErrorMessage))
                                {
                                    <span class="queue-error">@item.ErrorMessage</span>
                                }
                            </div>
                            <div class="queue-progress">
                                @if (item.Status == "uploading")
                                {
                                    <div class="progress-bar">
                                        <div class="progress-fill" style="width: @item.Progress%"></div>
                                    </div>
                                    <span class="progress-text">@item.Progress%</span>
                                }
                                else if (item.Status == "success")
                                {
                                    <span class="status-icon success">✓</span>
                                }
                                else if (item.Status == "error")
                                {
                                    <span class="status-icon error">✗</span>
                                }
                                else
                                {
                                    <span class="status-icon pending">⏳</span>
                                }
                            </div>
                            <button class="queue-remove" type="button"
                                    @onclick="@(() => RemoveFromQueue(item))">✕</button>
                        </div>
                    }
                </div>

                <div class="upload-actions">
                    <SecondaryButton OnClick="CloseUploadModal"
                                     Variant="SecondaryButton.ButtonVariant.Outline"
                                     IsDisabled="@isUploading"
                                     Size="SecondaryButton.ButtonSize.Medium">
                        Cancel
                    </SecondaryButton>
                    <PrimaryButton OnClick="StartUpload"
                                   IsDisabled="@isUploading"
                                   IsLoading="@isUploading"
                                   Size="PrimaryButton.ButtonSize.Medium">
                        Upload @uploadQueue.Count Image@(uploadQueue.Count != 1 ? "s" : "")
                    </PrimaryButton>
                </div>
            }
        </div>
    </BodyContent>
</DynamicModal>

<!-- ══ Convert Modal ══ -->
<DynamicModal @ref="convertModal"
              Title="Convert Image Format"
              Size="DynamicModal.ModalSize.Medium"
              IsOpen="@isConversionModalOpen"
              ShowFooter="false"
              OnClose="CancelConvert">
    <BodyContent>
        @if (conversionImage != null)
        {
            <div class="convert-modal-content">
                <div class="convert-preview-row">
                    <div class="convert-thumb">
                        <img src="@conversionImage.ThumbnailUrl" alt="@conversionImage.FileName" />
                    </div>
                    <div class="convert-source-info">
                        <span class="convert-filename">@conversionImage.FileName</span>
                        <span class="convert-meta">Current: <strong>@conversionImage.FileExtension</strong></span>
                        <span class="convert-meta">Size: <strong>@conversionImage.FormattedSize</strong></span>
                        <span class="convert-meta">Category: <strong>@GetCategoryDisplayName(conversionImage.Folder)</strong></span>
                    </div>
                </div>

                <div class="convert-section">
                    <label class="convert-section-label">Target Format</label>
                    <div class="convert-format-options">
                        <label class="format-option @(conversionFormat == "image/webp" ? "selected" : "")">
                            <input type="radio" name="format" value="image/webp"
                                   checked="@(conversionFormat == "image/webp")"
                                   @onchange="@(() => conversionFormat = "image/webp")" />
                            <span class="format-label">
                                <strong>WebP</strong>
                                <small>Best for web — smallest file size</small>
                            </span>
                        </label>
                        <label class="format-option @(conversionFormat == "image/jpeg" ? "selected" : "")">
                            <input type="radio" name="format" value="image/jpeg"
                                   checked="@(conversionFormat == "image/jpeg")"
                                   @onchange="@(() => conversionFormat = "image/jpeg")" />
                            <span class="format-label">
                                <strong>JPEG</strong>
                                <small>Maximum compatibility</small>
                            </span>
                        </label>
                        <label class="format-option @(conversionFormat == "image/png" ? "selected" : "")">
                            <input type="radio" name="format" value="image/png"
                                   checked="@(conversionFormat == "image/png")"
                                   @onchange="@(() => conversionFormat = "image/png")" />
                            <span class="format-label">
                                <strong>PNG</strong>
                                <small>Lossless — larger files</small>
                            </span>
                        </label>
                    </div>
                </div>

                @if (conversionFormat != "image/png")
                {
                    <div class="convert-section">
                        <label class="convert-section-label">
                            Quality: <strong>@conversionQuality%</strong>
                        </label>
                        <input type="range"
                               class="quality-slider"
                               min="10" max="100" step="5"
                               value="@conversionQuality"
                               @oninput="@((e) => conversionQuality = int.Parse(e.Value?.ToString() ?? "85"))" />
                        <div class="quality-hints">
                            <span>Low (smaller)</span>
                            <span>High (better quality)</span>
                        </div>
                    </div>
                }

                <div class="convert-section">
                    <label class="convert-replace-label">
                        <input type="checkbox" @bind="replaceOriginal" />
                        <span>Delete original after conversion</span>
                    </label>
                    <p class="convert-hint">
                        @if (replaceOriginal)
                        {
                            <span class="hint-warning">⚠ The original file will be permanently removed.</span>
                        }
                        else
                        {
                            <span>Both files will exist. You can delete the original manually later.</span>
                        }
                    </p>
                </div>

                <div class="convert-actions">
                    <SecondaryButton Variant="SecondaryButton.ButtonVariant.Outline"
                                     OnClick="CancelConvert"
                                     IsDisabled="@isConverting"
                                     Size="SecondaryButton.ButtonSize.Medium">
                        Cancel
                    </SecondaryButton>
                    <PrimaryButton OnClick="ConfirmConvert"
                                   IsLoading="@isConverting"
                                   IsDisabled="@isConverting"
                                   Size="PrimaryButton.ButtonSize.Medium">
                        @(isConverting ? "Converting…" : $"Convert to {GetFormatLabel(conversionFormat)}")
                    </PrimaryButton>
                </div>
            </div>
        }
    </BodyContent>
</DynamicModal>

<!-- ══ Move Modal ══ -->
<DynamicModal @ref="moveModal"
              Title="Move to Category"
              Size="DynamicModal.ModalSize.Small"
              IsOpen="@isMoveModalOpen"
              ShowFooter="false"
              OnClose="CancelMove">
    <BodyContent>
        @if (moveImage != null)
        {
            <div class="move-modal-content">
                <div class="move-preview-row">
                    <div class="move-thumb">
                        <img src="@moveImage.ThumbnailUrl" alt="@moveImage.FileName" />
                    </div>
                    <div class="move-info">
                        <span class="move-filename">@moveImage.FileName</span>
                        <span class="move-current">
                            Currently in: <strong>@GetCategoryDisplayName(moveImage.Folder)</strong>
                        </span>
                    </div>
                </div>

                <div class="move-select-section">
                    <label class="move-label">Move to</label>
                    <select class="upload-select" @bind="moveTargetFolder">
                        @foreach (var cat in categories.Where(c => c.IsActive).OrderBy(c => c.DisplayOrder))
                        {
                            <option value="@cat.Slug">@cat.Name</option>
                        }
                    </select>
                </div>

                @if (moveTargetFolder == moveImage.Folder)
                {
                    <p class="move-same-folder-hint">Select a different category to move the image.</p>
                }

                <div class="convert-actions">
                    <SecondaryButton Variant="SecondaryButton.ButtonVariant.Outline"
                                     OnClick="CancelMove"
                                     IsDisabled="@isMoving"
                                     Size="SecondaryButton.ButtonSize.Medium">
                        Cancel
                    </SecondaryButton>
                    <PrimaryButton OnClick="ConfirmMove"
                                   IsLoading="@isMoving"
                                   IsDisabled="@(isMoving || moveTargetFolder == moveImage.Folder)"
                                   Size="PrimaryButton.ButtonSize.Medium">
                        @(isMoving ? "Moving…" : "Move Image")
                    </PrimaryButton>
                </div>
            </div>
        }
    </BodyContent>
</DynamicModal>

<!-- ══ Delete Confirmation ══ -->
<ConfirmationPopup @ref="confirmationPopup"
                   IsOpen="@isConfirmationOpen"
                   Title="@(imageToDelete != null ? "Delete Image?" : $"Delete {imagesToDelete.Count} Images?")"
                   Message="@(imageToDelete != null
                       ? $"Are you sure you want to delete \"{imageToDelete.FileName}\"?"
                       : $"Are you sure you want to delete {imagesToDelete.Count} selected images?")"
                   WarningText="This action cannot be undone."
                   Variant="ConfirmationPopup.ConfirmationVariant.Danger"
                   ConfirmButtonText="@(isDeleting ? "Deleting…" : "Delete")"
                   CancelButtonText="Cancel"
                   IsProcessing="@isDeleting"
                   OnConfirm="ConfirmDelete"
                   OnCancel="CancelDelete" />

<!-- ══ Notifications ══ -->
<NotificationComponent @ref="notificationComponent"
                       Position="NotificationPosition.TopRight"
                       AutoDismissTime="5000" />
