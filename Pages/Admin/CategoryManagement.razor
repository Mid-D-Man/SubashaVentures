@page "/admin/categories"
@using SubashaVentures.Layout.Admin
@using SubashaVentures.Components.Shared.Buttons
@using SubashaVentures.Components.Shared.Forms
@using SubashaVentures.Components.Shared.Modals
@using SubashaVentures.Components.Shared.Notifications
@using SubashaVentures.Domain.Enums
@using SubashaVentures.Domain.Product
@layout AdminLayout

<div class="category-management">

    <div class="cm-header">
        <div class="cm-header-left">
            <h1 class="cm-title">Category Management</h1>
            <p class="cm-subtitle">Manage main categories and their subcategories</p>
        </div>
        <div class="cm-header-right">
            <PrimaryButton Variant="PrimaryButton.ButtonVariant.Primary"
                           Size="PrimaryButton.ButtonSize.Medium"
                           Icon="+"
                           OnClick="OpenAddCategoryModal">
                Add Category
            </PrimaryButton>
        </div>
    </div>

    <div class="cm-stats">
        <div class="stat-card">
            <div class="stat-icon">📂</div>
            <div class="stat-info">
                <span class="stat-label">Main Categories</span>
                <span class="stat-value">@categories.Count</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🗂️</div>
            <div class="stat-info">
                <span class="stat-label">Total Subcategories</span>
                <span class="stat-value">@categories.Sum(c => c.SubCategories.Count)</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">✅</div>
            <div class="stat-info">
                <span class="stat-label">Active Categories</span>
                <span class="stat-value">@categories.Count(c => c.IsActive)</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📦</div>
            <div class="stat-info">
                <span class="stat-label">Total Products</span>
                <span class="stat-value">@categories.Sum(c => c.ProductCount)</span>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="cm-loading">
            <div class="loading-spinner"></div>
            <p>Loading categories...</p>
        </div>
    }
    else if (!categories.Any())
    {
        <div class="cm-empty">
            <div class="empty-icon">📂</div>
            <h3>No categories yet</h3>
            <p>Create your first main category to get started</p>
            <PrimaryButton OnClick="OpenAddCategoryModal">Add Category</PrimaryButton>
        </div>
    }
    else
    {
        <div class="cm-tree">
            @foreach (var category in categories.OrderBy(c => c.DisplayOrder))
            {
                <div class="cm-category-block @(!category.IsActive ? "inactive" : "")">

                    <div class="cm-category-row">
                        <button class="expand-btn @(expandedCategories.Contains(category.Id) ? "expanded" : "")"
                                @onclick="() => ToggleExpand(category.Id)">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            </svg>
                        </button>

                        <div class="cm-category-icon">
                            @if (category.IconSvgType != SvgType.None && categorySvgCache.ContainsKey(category.Id))
                            {
                                @((MarkupString)categorySvgCache[category.Id])
                            }
                        </div>

                        <div class="cm-category-info">
                            <span class="cm-category-name">@category.Name</span>
                            <span class="cm-category-slug">@category.Slug</span>
                        </div>

                        <div class="cm-category-meta">
                            <span class="meta-badge products">@category.ProductCount products</span>
                            <span class="meta-badge subs">@category.SubCategories.Count subcategories</span>
                            <span class="status-badge @(category.IsActive ? "active" : "inactive")">
                                @(category.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>

                        <div class="cm-category-actions">
                            <button class="action-btn add-sub"
                                    @onclick="() => OpenAddSubCategoryModal(category)"
                                    title="Add Subcategory">
                                ➕
                            </button>
                            <button class="action-btn edit"
                                    @onclick="() => OpenEditCategoryModal(category)"
                                    title="Edit Category">
                                ✏️
                            </button>
                            <button class="action-btn delete"
                                    @onclick="() => HandleDeleteCategory(category)"
                                    disabled="@(category.ProductCount > 0)"
                                    title="@(category.ProductCount > 0 ? "Has products" : "Delete")">
                                🗑️
                            </button>
                        </div>
                    </div>

                    @if (expandedCategories.Contains(category.Id))
                    {
                        <div class="cm-subcategory-list">
                            @if (!category.SubCategories.Any())
                            {
                                <div class="no-subs-message">
                                    <span>No subcategories yet.</span>
                                    <button class="inline-add-btn" @onclick="() => OpenAddSubCategoryModal(category)">
                                        + Add one
                                    </button>
                                </div>
                            }
                            else
                            {
                                @foreach (var sub in category.SubCategories.OrderByDescending(s => s.IsDefault).ThenBy(s => s.DisplayOrder))
                                {
                                    <div class="cm-sub-row @(!sub.IsActive ? "inactive" : "") @(sub.IsDefault ? "is-default" : "")">

                                        <div class="sub-icon">
                                            @if (sub.IconSvgType != SvgType.None && subCategorySvgCache.ContainsKey(sub.Id))
                                            {
                                                @((MarkupString)subCategorySvgCache[sub.Id])
                                            }
                                        </div>

                                        <div class="sub-info">
                                            <span class="sub-name">@sub.Name</span>
                                            <span class="sub-slug">@sub.Slug</span>
                                        </div>

                                        <div class="sub-meta">
                                            @if (sub.IsDefault)
                                            {
                                                <span class="default-badge">Default</span>
                                            }
                                            <span class="meta-badge products">@sub.ProductCount products</span>
                                            <span class="status-badge @(sub.IsActive ? "active" : "inactive")">
                                                @(sub.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </div>

                                        <div class="sub-actions">
                                            @if (!sub.IsDefault)
                                            {
                                                <button class="action-btn set-default"
                                                        @onclick="() => HandleSetDefault(sub, category.Id)"
                                                        title="Set as Default">
                                                    ⭐
                                                </button>
                                            }
                                            <button class="action-btn edit"
                                                    @onclick="() => OpenEditSubCategoryModal(sub, category)"
                                                    title="Edit">
                                                ✏️
                                            </button>
                                            <button class="action-btn delete"
                                                    @onclick="() => HandleDeleteSubCategory(sub)"
                                                    disabled="@(sub.ProductCount > 0 || sub.IsDefault)"
                                                    title="@GetSubDeleteTooltip(sub)">
                                                🗑️
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@* ==================== CATEGORY MODAL ==================== *@
<DynamicModal @ref="categoryModal"
              Title="@(isEditMode ? "Edit Category" : "Add Category")"
              Size="DynamicModal.ModalSize.Medium"
              IsOpen="@isCategoryModalOpen"
              ShowFooter="false"
              OnClose="CloseCategoryModal">
    <BodyContent>
        <div class="cm-form">
            <InputField @bind-Value="categoryForm.Name"
                        Label="Category Name"
                        Placeholder="e.g., Men"
                        IsRequired="true"
                        HasError="@(!string.IsNullOrEmpty(validationErrors.GetValueOrDefault("Name")))"
                        ErrorMessage="@validationErrors.GetValueOrDefault("Name")"
                        CssClass="form-field" />

            <InputField @bind-Value="categoryForm.Slug"
                        Label="Slug"
                        Placeholder="Auto-generated from name"
                        HelperText="Leave empty to auto-generate"
                        CssClass="form-field" />

            <div class="form-field">
                <label class="input-label">Description</label>
                <textarea class="input-control textarea"
                          @bind="categoryForm.Description"
                          placeholder="Optional description"
                          rows="3"></textarea>
            </div>

            <div class="form-field">
                <label class="input-label">Category Icon</label>
                <div class="icon-preview-container" @onclick="ToggleCategoryIconPicker">
                    @if (categoryForm.IconSvgType != SvgType.None && selectedCategoryIconSvg != null)
                    {
                        <div class="selected-icon">@((MarkupString)selectedCategoryIconSvg)</div>
                        <span class="selected-icon-name">@categoryForm.IconSvgType.ToString()</span>
                    }
                    else
                    {
                        <div class="selected-icon-placeholder"><span>No icon</span></div>
                    }
                    <button type="button" class="icon-picker-toggle">@(showCategoryIconPicker ? "▲" : "▼")</button>
                </div>
                @if (showCategoryIconPicker)
                {
                    <div class="icon-picker-dropdown">
                        <div class="icon-picker-grid">
                            @foreach (var iconType in availableIcons)
                            {
                                var svg = iconSvgCache.GetValueOrDefault(iconType, "");
                                <div class="icon-picker-item @(categoryForm.IconSvgType == iconType ? "selected" : "")"
                                     @onclick="() => SelectCategoryIcon(iconType)"
                                     title="@iconType.ToString()">
                                    @((MarkupString)svg)
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="form-field">
                <label class="input-label">Display Order</label>
                <input type="number" class="input-control" @bind="categoryForm.DisplayOrder" min="0" />
            </div>

            @if (isEditMode)
            {
                <div class="form-field">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="categoryForm.IsActive" />
                        <span class="toggle-slider"></span>
                        <span class="toggle-label">Active</span>
                    </label>
                </div>
            }

            <div class="modal-actions">
                <SecondaryButton OnClick="CloseCategoryModal"
                                 Variant="SecondaryButton.ButtonVariant.Outline"
                                 IsDisabled="@isSaving">
                    Cancel
                </SecondaryButton>
                <PrimaryButton OnClick="SaveCategory"
                               IsLoading="@isSaving"
                               IsDisabled="@isSaving">
                    @(isEditMode ? "Update" : "Create") Category
                </PrimaryButton>
            </div>
        </div>
    </BodyContent>
</DynamicModal>

@* ==================== SUBCATEGORY MODAL ==================== *@
<DynamicModal @ref="subCategoryModal"
              Title="@(isEditSubMode ? $"Edit Subcategory — {activeParentCategory?.Name}" : $"Add Subcategory — {activeParentCategory?.Name}")"
              Size="DynamicModal.ModalSize.Medium"
              IsOpen="@isSubCategoryModalOpen"
              ShowFooter="false"
              OnClose="CloseSubCategoryModal">
    <BodyContent>
        <div class="cm-form">
            <InputField @bind-Value="subCategoryForm.Name"
                        Label="Subcategory Name"
                        Placeholder="e.g., Footwear"
                        IsRequired="true"
                        HasError="@(!string.IsNullOrEmpty(validationErrors.GetValueOrDefault("SubName")))"
                        ErrorMessage="@validationErrors.GetValueOrDefault("SubName")"
                        CssClass="form-field" />

            <InputField @bind-Value="subCategoryForm.Slug"
                        Label="Slug"
                        Placeholder="Auto-generated"
                        HelperText="Leave empty to auto-generate"
                        CssClass="form-field" />

            <div class="form-field">
                <label class="input-label">Description</label>
                <textarea class="input-control textarea"
                          @bind="subCategoryForm.Description"
                          placeholder="Optional description"
                          rows="3"></textarea>
            </div>

            <div class="form-field">
                <label class="input-label">Subcategory Icon</label>
                <div class="icon-preview-container" @onclick="ToggleSubIconPicker">
                    @if (subCategoryForm.IconSvgType != SvgType.None && selectedSubIconSvg != null)
                    {
                        <div class="selected-icon">@((MarkupString)selectedSubIconSvg)</div>
                        <span class="selected-icon-name">@subCategoryForm.IconSvgType.ToString()</span>
                    }
                    else
                    {
                        <div class="selected-icon-placeholder"><span>No icon</span></div>
                    }
                    <button type="button" class="icon-picker-toggle">@(showSubIconPicker ? "▲" : "▼")</button>
                </div>
                @if (showSubIconPicker)
                {
                    <div class="icon-picker-dropdown">
                        <div class="icon-picker-grid">
                            @foreach (var iconType in availableIcons)
                            {
                                var svg = iconSvgCache.GetValueOrDefault(iconType, "");
                                <div class="icon-picker-item @(subCategoryForm.IconSvgType == iconType ? "selected" : "")"
                                     @onclick="() => SelectSubIcon(iconType)"
                                     title="@iconType.ToString()">
                                    @((MarkupString)svg)
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="form-field">
                <label class="input-label">Display Order</label>
                <input type="number" class="input-control" @bind="subCategoryForm.DisplayOrder" min="0" />
            </div>

            <div class="form-field">
                <label class="toggle-switch">
                    <input type="checkbox" @bind="subCategoryForm.IsDefault" />
                    <span class="toggle-slider"></span>
                    <span class="toggle-label">Set as Default Subcategory</span>
                </label>
                <span class="helper-text">The default subcategory is pre-selected when browsing this category.</span>
            </div>

            @if (isEditSubMode)
            {
                <div class="form-field">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="subCategoryForm.IsActive" />
                        <span class="toggle-slider"></span>
                        <span class="toggle-label">Active</span>
                    </label>
                </div>
            }

            <div class="modal-actions">
                <SecondaryButton OnClick="CloseSubCategoryModal"
                                 Variant="SecondaryButton.ButtonVariant.Outline"
                                 IsDisabled="@isSaving">
                    Cancel
                </SecondaryButton>
                <PrimaryButton OnClick="SaveSubCategory"
                               IsLoading="@isSaving"
                               IsDisabled="@isSaving">
                    @(isEditSubMode ? "Update" : "Create") Subcategory
                </PrimaryButton>
            </div>
        </div>
    </BodyContent>
</DynamicModal>

<ConfirmationPopup @ref="confirmationPopup"
                   IsOpen="@isConfirmationOpen"
                   Title="@confirmTitle"
                   Message="@confirmMessage"
                   WarningText="This action cannot be undone."
                   Variant="ConfirmationPopup.ConfirmationVariant.Danger"
                   ConfirmButtonText="Delete"
                   CancelButtonText="Cancel"
                   IsProcessing="@isDeleting"
                   OnConfirm="ConfirmDelete"
                   OnCancel="CancelDelete" />

<NotificationComponent @ref="notificationComponent"
                       Position="NotificationPosition.TopRight"
                       AutoDismissTime="5000" />
