@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using SubashaVentures.Domain.Enums
@using SubashaVentures.Services.VisualElements
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IVisualElementsService VisualElements
@namespace SubashaVentures.Layout.Partner

<div class="partner-layout">

    <aside class="partner-sidebar @(isMobileOpen ? "mobile-open" : "")">

        <div class="partner-sidebar-brand">
            <a href="" class="partner-logo-link">
                <span class="partner-logo-text">SV</span>
            </a>
            <div class="partner-identity">
                <span class="partner-hub-label">Partner Hub</span>
                <span class="partner-display-name">@PartnerName</span>
            </div>
        </div>

        <nav class="partner-nav">
            <a href="user/partner/dashboard"
               class="partner-nav-item @(IsActive("dashboard") ? "active" : "")"
               @onclick="CloseMobile">
                <span class="pni">@((MarkupString)dashSvg)</span>
                <span class="pnt">Dashboard</span>
            </a>
            <a href="user/partner/templates"
               class="partner-nav-item @(IsActive("templates") ? "active" : "")"
               @onclick="CloseMobile">
                <span class="pni">@((MarkupString)productsSvg)</span>
                <span class="pnt">Products</span>
            </a>
            <a href="user/partner/financials"
               class="partner-nav-item @(IsActive("financials") ? "active" : "")"
               @onclick="CloseMobile">
                <span class="pni">@((MarkupString)financialsSvg)</span>
                <span class="pnt">Financials</span>
            </a>
            <a href="user/partner/store"
               class="partner-nav-item @(IsActive("store") ? "active" : "")"
               @onclick="CloseMobile">
                <span class="pni">@((MarkupString)storeSvg)</span>
                <span class="pnt">My Store</span>
            </a>
        </nav>

        <div class="partner-sidebar-footer">
            <a href="user" class="partner-nav-item partner-back-link">
                <span class="pni">@((MarkupString)backSvg)</span>
                <span class="pnt">My Account</span>
            </a>
        </div>

    </aside>

    <div class="partner-content-wrapper">

        <header class="partner-top-bar">
            <button class="partner-burger" @onclick="ToggleMobile" aria-label="Toggle menu">
                @((MarkupString)menuSvg)
            </button>
            <span class="partner-top-title">Partner Hub</span>
            <a href="user" class="partner-top-account">← Account</a>
        </header>

        <main class="partner-main">
            @Body
        </main>

    </div>

    @if (isMobileOpen)
    {
        <div class="partner-backdrop" @onclick="CloseMobile"></div>
    }

</div>

@code {
    private bool   isMobileOpen = false;
    private string PartnerName  = "Partner";

    private string dashSvg       = string.Empty;
    private string productsSvg   = string.Empty;
    private string financialsSvg = string.Empty;
    private string storeSvg      = string.Empty;
    private string backSvg       = string.Empty;
    private string menuSvg       = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadUserNameAsync(), LoadSvgsAsync());
    }

    private async Task LoadUserNameAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (user.Identity?.IsAuthenticated != true) return;

            var first = user.FindFirst("first_name")?.Value ?? "";
            var last  = user.FindFirst("last_name")?.Value  ?? "";
            PartnerName = $"{first} {last}".Trim();
            if (string.IsNullOrEmpty(PartnerName))
                PartnerName = user.Identity.Name ?? "Partner";
        }
        catch { /* non-fatal */ }
    }

    private async Task LoadSvgsAsync()
    {
        try
        {
            dashSvg       = await VisualElements.GetCustomSvgAsync(SvgType.Stats,       24, 24);
            productsSvg   = await VisualElements.GetCustomSvgAsync(SvgType.AllProducts, 24, 24);
            financialsSvg = await VisualElements.GetCustomSvgAsync(SvgType.Payment,     24, 24);
            storeSvg      = await VisualElements.GetCustomSvgAsync(SvgType.ShopNow,     24, 24);

            backSvg = VisualElements.GenerateSvg(
                "<path stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' " +
                "d='M19 12H5M12 19l-7-7 7-7'/>",
                24, 24, "0 0 24 24", "fill='none'");

            menuSvg = VisualElements.GenerateSvg(
                "<path stroke='currentColor' stroke-width='2' stroke-linecap='round' " +
                "d='M4 6h16M4 12h16M4 18h16'/>",
                24, 24, "0 0 24 24", "fill='none'");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"PartnerLayout SVG error: {ex.Message}");
        }
    }

    private bool IsActive(string segment) =>
        Navigation.ToBaseRelativePath(Navigation.Uri)
                  .Contains(segment, StringComparison.OrdinalIgnoreCase);

    private void ToggleMobile()
    {
        isMobileOpen = !isMobileOpen;
        StateHasChanged();
    }

    private void CloseMobile()
    {
        isMobileOpen = false;
        StateHasChanged();
    }
}
