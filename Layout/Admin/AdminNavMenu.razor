@using Microsoft.AspNetCore.Components.Authorization
@using SubashaVentures.Services.VisualElements
@using SubashaVentures.Domain.Enums
@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IVisualElementsService VisualElements
@inject AuthenticationStateProvider AuthStateProvider
@namespace SubashaVentures.Layout.Admin

<nav class="admin-nav @(isCollapsed ? "collapsed" : "")">

    <div class="admin-nav-header">
        @if (!isCollapsed)
        {
            <span class="admin-nav-logo">Admin</span>
        }
        <button class="nav-collapse-btn" @onclick="ToggleCollapse" aria-label="Toggle sidebar">
            <span>@((MarkupString)collapseIconSvg)</span>
        </button>
    </div>

    <div class="admin-nav-scroll">

        <!-- ── Overview ── -->
        <div class="nav-section-label @(isCollapsed ? "hidden" : "")">Overview</div>

        <NavItem Href="admin"
                 Icon="@dashSvg"
                 Label="Dashboard"
                 IsCollapsed="@isCollapsed"
                 ExactMatch="true" />

        <NavItem Href="admin/analytics"
                 Icon="@analyticsSvg"
                 Label="Analytics"
                 IsCollapsed="@isCollapsed" />

        <!-- ── Commerce ── -->
        <div class="nav-section-label @(isCollapsed ? "hidden" : "")">Commerce</div>

        <NavItem Href="admin/orders"
                 Icon="@orderSvg"
                 Label="Orders"
                 IsCollapsed="@isCollapsed" />

        <NavItem Href="admin/products"
                 Icon="@productSvg"
                 Label="Products"
                 IsCollapsed="@isCollapsed" />

        <NavItem Href="admin/categories"
                 Icon="@categorySvg"
                 Label="Categories"
                 IsCollapsed="@isCollapsed" />

        <NavItem Href="admin/inventory"
                 Icon="@inventorySvg"
                 Label="Inventory"
                 IsCollapsed="@isCollapsed" />

        <!-- ── Partners ── -->
        <div class="nav-section-label @(isCollapsed ? "hidden" : "")">Partners</div>

        <NavItem Href="admin/partner-applications"
                 Icon="@partnerAppSvg"
                 Label="Applications"
                 IsCollapsed="@isCollapsed" />

        <NavItem Href="admin/partner-templates"
                 Icon="@partnerTemplateSvg"
                 Label="Template Review"
                 IsCollapsed="@isCollapsed"
                 BadgeCount="@pendingTemplateCount" />

        <NavItem Href="admin/partner-payouts"
                 Icon="@partnerPayoutSvg"
                 Label="Payouts"
                 IsCollapsed="@isCollapsed"
                 BadgeCount="@pendingPayoutCount" />

        <!-- ── Users ── -->
        <div class="nav-section-label @(isCollapsed ? "hidden" : "")">Users</div>

        <NavItem Href="admin/users"
                 Icon="@usersSvg"
                 Label="All Users"
                 IsCollapsed="@isCollapsed" />

        <NavItem Href="admin/users/segments"
                 Icon="@segmentSvg"
                 Label="Segmentation"
                 IsCollapsed="@isCollapsed" />

        <!-- ── Marketing ── -->
        <div class="nav-section-label @(isCollapsed ? "hidden" : "")">Marketing</div>

        <NavItem Href="admin/newsletter"
                 Icon="@newsletterSvg"
                 Label="Newsletter"
                 IsCollapsed="@isCollapsed" />

        <NavItem Href="admin/offers"
                 Icon="@offerSvg"
                 Label="Offers"
                 IsCollapsed="@isCollapsed" />

        <NavItem Href="admin/banners"
                 Icon="@bannerSvg"
                 Label="Banners"
                 IsCollapsed="@isCollapsed" />

        <!-- ── Support ── -->
        <div class="nav-section-label @(isCollapsed ? "hidden" : "")">Support</div>

        <NavItem Href="admin/support"
                 Icon="@supportSvg"
                 Label="Support Tickets"
                 IsCollapsed="@isCollapsed" />

        <NavItem Href="admin/reviews"
                 Icon="@reviewSvg"
                 Label="Reviews"
                 IsCollapsed="@isCollapsed" />

        <!-- ── System ── -->
        <div class="nav-section-label @(isCollapsed ? "hidden" : "")">System</div>

        <NavItem Href="admin/admins"
                 Icon="@adminUserSvg"
                 Label="Admin Users"
                 IsCollapsed="@isCollapsed" />

        <NavItem Href="admin/settings"
                 Icon="@settingsSvg"
                 Label="Settings"
                 IsCollapsed="@isCollapsed" />

        <NavItem Href="admin/logs"
                 Icon="@logsSvg"
                 Label="Logs"
                 IsCollapsed="@isCollapsed" />
    </div>

    <div class="admin-nav-footer">
        <div class="admin-nav-admin-info @(isCollapsed ? "collapsed" : "")">
            @if (!isCollapsed)
            {
                <span class="admin-nav-name">@adminName</span>
                <span class="admin-nav-role">@adminRole</span>
            }
        </div>
        <NavItem Href="signout"
                 Icon="@signOutSvg"
                 Label="Sign Out"
                 IsCollapsed="@isCollapsed"
                 CssClass="nav-signout" />
    </div>
</nav>
